#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE="$LINK_TARGET"
  else
    SOURCE="$SOURCE_DIR/$LINK_TARGET"
  fi
done
PACKAGE_ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
PROJECT_ROOT="$(pwd)"
CONFIG="$PROJECT_ROOT/agentflow.config.yml"
FEATURE_DIR="$PROJECT_ROOT/features"
DOCS_DIR="$PROJECT_ROOT/project-docs"
STATE_DIR="$PROJECT_ROOT/.agentflow/state"
MODULES_DIR="$PROJECT_ROOT/.agentflow/modules"
ACTIVE_CONTEXT_FILE="active_context.json"
ACTIVE_CONTEXT_MD_FILE="active_context.md"
TEMPLATE_DIR="$PACKAGE_ROOT/agentflow/templates"
PROFILE="standard"
INIT_FORCE="false"
VERIFY_ERRORS=()
VERIFY_WARNINGS=()

usage() {
  cat <<'USAGE'
Usage:
  Daily workflow:
  bin/agentflow init [--profile lite|standard|full] [--force]
  bin/agentflow feature create "Feature title" [--type trivial|bug|standard|major|sensitive]
  bin/agentflow feature next FEATURE-001-title
  bin/agentflow feature status FEATURE-001-title

Advanced feature commands:
  bin/agentflow feature verify FEATURE-001-title --stage spec|plan|tasks|dispatch|implement|test|review|fix|archive|done
  bin/agentflow feature gate FEATURE-001-title --to plan|tasks|dispatch|implement|test|review|fix|archive
  bin/agentflow feature advance FEATURE-001-title --to plan|tasks|dispatch|implement|test|review|fix|archive
  bin/agentflow feature context FEATURE-001-title
  bin/agentflow feature sync FEATURE-001-title
  bin/agentflow feature dispatch FEATURE-001-title
  bin/agentflow stage plan FEATURE-001-title --stage spec|plan|tasks [--adapter codex]
  bin/agentflow stage run FEATURE-001-title --stage spec|plan|tasks [--adapter codex] [--execute]
  bin/agentflow dispatch plan FEATURE-001-title [--adapter codex]
  bin/agentflow dispatch run FEATURE-001-title [--adapter codex] [--execute]
  bin/agentflow feature archive FEATURE-001-title
  bin/agentflow architecture check
  bin/agentflow board render
  bin/agentflow board render --check
  bin/agentflow state migrate
  bin/agentflow update --check
  bin/agentflow update --apply
  bin/agentflow doctor
  bin/agentflow install-hooks
  bin/agentflow init-ci github
  bin/agentflow init-rules cursor|cline|codex|all
  bin/agentflow module list
  bin/agentflow module show MODULE_ID
  bin/agentflow module add MODULE_ID --name NAME --source-type public|internal|third-party --source SOURCE --module-type TYPE --domain DOMAIN --risk low|medium|high|critical --mode reference-only|dependency|vendor|direct-copy
  bin/agentflow module contract MODULE_ID
  bin/agentflow module approve MODULE_ID --mode reference-only|dependency|vendor|direct-copy [--human-approved] [--approved-by NAME]
  bin/agentflow reuse analyze FEATURE-001-title
  bin/agentflow reuse gate FEATURE-001-title
  bin/agentflow approve FEATURE-001-title --stage spec|plan|tasks|implementation

Legacy aliases:
  bin/agentflow feature "Feature title"
  bin/agentflow check FEATURE-001-title
  bin/agentflow gate spec|plan|tasks|implement|review|archive FEATURE-001-title
  bin/agentflow verify FEATURE-001-title --stage spec|plan|tasks|dispatch|implement|test|review|fix|archive|done
  bin/agentflow gate FEATURE-001-title --to plan|tasks|dispatch|implement|test|review|fix|archive
  bin/agentflow context FEATURE-001-title
  bin/agentflow status FEATURE-001-title
  bin/agentflow sync-tasks FEATURE-001-title
  bin/agentflow dispatch FEATURE-001-title
  bin/agentflow archive FEATURE-001-title
USAGE
}

package_version() {
  awk '
    /^[[:space:]]*"version":[[:space:]]*/ {
      line = $0
      sub(/^[^:]+:[[:space:]]*"/, "", line)
      sub(/".*$/, "", line)
      print line
      exit
    }
  ' "$PACKAGE_ROOT/package.json"
}

parse_profile() {
  local profile="standard"
  INIT_FORCE="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        if [[ $# -lt 2 ]]; then
          printf 'Missing value for --profile\n' >&2
          exit 1
        fi
        profile="$2"
        shift 2
        ;;
      --profile=*)
        profile="${1#--profile=}"
        shift
        ;;
      --force)
        INIT_FORCE="true"
        shift
        ;;
      lite|standard|full)
        profile="$1"
        shift
        ;;
      *)
        printf 'Unknown init option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  case "$profile" in
    lite|standard|full)
      printf '%s' "$profile"
      ;;
    *)
      printf 'Unknown profile: %s\n' "$profile" >&2
      exit 1
      ;;
  esac
}

parse_stage_flag() {
  local flag_name="$1"
  shift
  local value=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      "$flag_name")
        if [[ $# -lt 2 ]]; then
          printf 'Missing value for %s\n' "$flag_name" >&2
          exit 1
        fi
        value="$2"
        shift 2
        ;;
      "$flag_name"=*)
        value="${1#*=}"
        shift
        ;;
      *)
        printf 'Unknown option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$value" ]]; then
    printf 'Missing required %s option\n' "$flag_name" >&2
    exit 1
  fi

  printf '%s' "$value"
}

slugify() {
  printf '%s' "$1" |
    tr '[:upper:]' '[:lower:]' |
    sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

yaml_nested_value() {
  local section="$1"
  local key="$2"
  local file="$3"
  awk -v section="$section" -v key="$key" '
    $0 ~ "^" section ":" {
      in_section = 1
      next
    }
    in_section && $0 ~ "^[^[:space:]]" {
      in_section = 0
    }
    in_section {
      line = $0
      gsub(/^[[:space:]]+/, "", line)
      if (line ~ "^" key ":") {
        sub("^[^:]+:[[:space:]]*", "", line)
        print line
        exit
      }
    }
  ' "$file"
}

yaml_three_level_value() {
  local section="$1"
  local subsection="$2"
  local key="$3"
  local file="$4"
  awk -v section="$section" -v subsection="$subsection" -v key="$key" '
    $0 ~ "^" section ":" {
      in_section = 1
      next
    }
    in_section && $0 ~ "^[^[:space:]]" {
      in_section = 0
      in_subsection = 0
    }
    in_section && $0 ~ "^[[:space:]]{2}" subsection ":" {
      in_subsection = 1
      next
    }
    in_subsection && $0 ~ "^[[:space:]]{2}[A-Za-z0-9_-]+:" {
      in_subsection = 0
    }
    in_subsection {
      line = $0
      gsub(/^[[:space:]]+/, "", line)
      if (line ~ "^" key ":") {
        sub("^[^:]+:[[:space:]]*", "", line)
        print line
        exit
      }
    }
  ' "$file"
}

yaml_list_under_section_key() {
  local section="$1"
  local key="$2"
  local file="$3"
  awk -v section="$section" -v key="$key" '
    $0 ~ "^" section ":" {
      in_section = 1
      next
    }
    in_section && $0 ~ "^[^[:space:]]" {
      if (in_key) {
        exit
      }
      in_section = 0
    }
    in_section {
      if ($0 ~ "^[[:space:]]{2}" key ":[[:space:]]*$") {
        in_key = 1
        next
      }
      if (in_key && $0 ~ "^[[:space:]]{2}[A-Za-z0-9_-]+:[[:space:]]*$") {
        exit
      }
      if (in_key && $0 ~ "^[[:space:]]*-[[:space:]]") {
        line = $0
        sub("^[[:space:]]*-[[:space:]]*", "", line)
        print line
      }
    }
  ' "$file"
}

resolve_project_path() {
  local raw_path="$1"
  if [[ -z "$raw_path" ]]; then
    return
  fi
  if [[ "$raw_path" == /* ]]; then
    printf '%s' "$raw_path"
  else
    printf '%s/%s' "$PROJECT_ROOT" "$raw_path"
  fi
}

load_project_paths() {
  local feature_dir="features"
  local docs_dir="project-docs"
  local state_dir=".agentflow/state"
  local active_context_file="active_context.json"

  if [[ -f "$CONFIG" ]]; then
    feature_dir="$(yaml_nested_value "project" "feature_dir" "$CONFIG" || true)"
    docs_dir="$(yaml_nested_value "project" "docs_dir" "$CONFIG" || true)"
    state_dir="$(yaml_nested_value "runtime" "state_dir" "$CONFIG" || true)"
    active_context_file="$(yaml_nested_value "runtime" "active_context_file" "$CONFIG" || true)"
    ACTIVE_CONTEXT_MD_FILE="$(yaml_nested_value "runtime" "active_context_markdown_file" "$CONFIG" || true)"
  fi

  FEATURE_DIR="$(resolve_project_path "${feature_dir:-features}")"
  DOCS_DIR="$(resolve_project_path "${docs_dir:-project-docs}")"
  STATE_DIR="$(resolve_project_path "${state_dir:-.agentflow/state}")"
  ACTIVE_CONTEXT_FILE="${active_context_file:-active_context.json}"
  ACTIVE_CONTEXT_MD_FILE="${ACTIVE_CONTEXT_MD_FILE:-active_context.md}"
}

config_bool() {
  local section="$1"
  local key="$2"
  local default_value="$3"
  local value="$default_value"
  if [[ -f "$CONFIG" ]]; then
    value="$(yaml_nested_value "$section" "$key" "$CONFIG" || true)"
  fi
  value="${value:-$default_value}"
  case "$value" in
    true|yes|1) printf 'true' ;;
    false|no|0) printf 'false' ;;
    *) printf '%s' "$default_value" ;;
  esac
}

config_string() {
  local section="$1"
  local key="$2"
  local default_value="$3"
  local value="$default_value"
  if [[ -f "$CONFIG" ]]; then
    value="$(yaml_nested_value "$section" "$key" "$CONFIG" || true)"
  fi
  value="${value:-$default_value}"
  printf '%s' "$value"
}

review_mode_for_stage() {
  local stage="$1"
  local review_key="$stage"
  local mode="self"
  case "$stage" in
    implement|implementation|review) review_key="implementation" ;;
  esac
  if [[ -f "$CONFIG" ]]; then
    mode="$(yaml_three_level_value "review" "$review_key" "mode" "$CONFIG" || true)"
  fi
  mode="${mode:-self}"
  case "$mode" in
    self|separate-session|human) printf '%s' "$mode" ;;
    *) printf 'self' ;;
  esac
}

config_list() {
  local section="$1"
  local key="$2"
  local default_values="$3"
  local values=""
  if [[ -f "$CONFIG" ]]; then
    values="$(yaml_list_under_section_key "$section" "$key" "$CONFIG" || true)"
  fi
  if [[ -n "$values" ]]; then
    printf '%s\n' "$values"
  else
    printf '%s\n' "$default_values"
  fi
}

implementation_target_sides() {
  config_list "implementation" "target_sides" "backend
frontend
mobile" |
    sed -E 's/[[:space:]]+#.*$//; s/^["'\'']//; s/["'\'']$//' |
    awk '
      $0 == "backend" || $0 == "frontend" || $0 == "mobile" {
        if (!seen[$0]++) print
      }
    '
}

valid_feature_type() {
  case "$1" in
    trivial|bug|standard|major|sensitive) return 0 ;;
    *) return 1 ;;
  esac
}

default_feature_type() {
  config_string "workflow" "default_type" "standard"
}

workflow_stages_for_type() {
  local type="$1"
  case "$type" in
    trivial) printf '%s\n' implement archive ;;
    bug) printf '%s\n' implement test archive ;;
    standard) printf '%s\n' spec plan tasks implement test archive ;;
    major) printf '%s\n' spec plan tasks dispatch implement test review fix archive ;;
    sensitive) printf '%s\n' spec reuse-risk plan tasks dispatch implement security-review test review fix archive ;;
    *) printf '%s\n' spec plan tasks dispatch implement test review fix archive ;;
  esac
}

feature_state_file_for_dir() {
  printf '%s/state.yml' "$1"
}

feature_state_value() {
  local dir="$1"
  local key="$2"
  local state_file
  state_file="$(feature_state_file_for_dir "$dir")"
  [[ -f "$state_file" ]] || return
  awk -v key="$key" '
    $0 ~ "^[[:space:]]*" key ":" {
      line = $0
      sub("^[^:]+:[[:space:]]*", "", line)
      gsub(/^"/, "", line)
      gsub(/"$/, "", line)
      print line
      exit
    }
  ' "$state_file"
}

feature_type_for_dir() {
  local dir="$1"
  local type
  type="$(feature_state_value "$dir" "type")"
  if [[ -n "$type" ]]; then
    printf '%s' "$type"
  else
    # Legacy feature bundles predate typed workflows and used the full flow.
    printf 'major'
  fi
}

feature_has_stage() {
  local dir="$1"
  local stage="$2"
  local type
  type="$(feature_type_for_dir "$dir")"
  workflow_stages_for_type "$type" | grep -Fxq "$stage"
}

previous_workflow_stage() {
  local dir="$1"
  local target="$2"
  local type stage previous=""
  type="$(feature_type_for_dir "$dir")"
  while IFS= read -r stage; do
    if [[ "$stage" == "$target" ]]; then
      printf '%s' "$previous"
      return
    fi
    previous="$stage"
  done < <(workflow_stages_for_type "$type")
}

next_workflow_stage() {
  local dir="$1"
  local current="$2"
  local type stage found=0
  type="$(feature_type_for_dir "$dir")"
  if [[ "$current" == "draft" ]]; then
    workflow_stages_for_type "$type" | head -1
    return
  fi
  while IFS= read -r stage; do
    if [[ "$found" -eq 1 ]]; then
      printf '%s' "$stage"
      return
    fi
    [[ "$stage" == "$current" ]] && found=1
  done < <(workflow_stages_for_type "$type")
  printf 'complete'
}

required_feature_files() {
  printf '%s\n' spec.md plan.md tasks.md dispatch.md archive.md implementation/api.md

  if [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]]; then
    printf '%s\n' spec-review.md
  fi
  if [[ "$(config_bool "gates" "require_plan_review" "true")" == "true" ]]; then
    printf '%s\n' plan-review.md
  fi
  if [[ "$(config_bool "gates" "require_task_review" "true")" == "true" ]]; then
    printf '%s\n' task-review.md
  fi
  if [[ "$(config_bool "gates" "require_tests_before_done" "true")" == "true" ]]; then
    printf '%s\n' implementation/test.md
  fi
  if [[ "$(config_bool "gates" "require_review_before_commit" "true")" == "true" ]]; then
    printf '%s\n' implementation/review.md
  fi

  local side
  while IFS= read -r side; do
    printf 'results/%s.md\n' "$side"
  done < <(implementation_target_sides)
  printf '%s\n' results/fix.md
}

required_feature_files_for_dir() {
  local dir="$1"
  local side
  feature_has_stage "$dir" "spec" && printf '%s\n' spec.md
  if feature_has_stage "$dir" "spec" && [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]]; then
    printf '%s\n' spec-review.md
  fi
  feature_has_stage "$dir" "reuse-risk" && printf '%s\n' reuse-analysis.md external-module-risk.md
  feature_has_stage "$dir" "plan" && printf '%s\n' plan.md
  if feature_has_stage "$dir" "plan" && [[ "$(config_bool "gates" "require_plan_review" "true")" == "true" ]]; then
    printf '%s\n' plan-review.md
  fi
  feature_has_stage "$dir" "tasks" && printf '%s\n' tasks.md
  if feature_has_stage "$dir" "tasks" && [[ "$(config_bool "gates" "require_task_review" "true")" == "true" ]]; then
    printf '%s\n' task-review.md
  fi
  feature_has_stage "$dir" "dispatch" && printf '%s\n' dispatch.md
  printf '%s\n' archive.md implementation/api.md state.yml
  while IFS= read -r side; do
    printf 'results/%s.md\n' "$side"
  done < <(implementation_target_sides)
  feature_has_stage "$dir" "test" && [[ "$(config_bool "gates" "require_tests_before_done" "true")" == "true" ]] && printf '%s\n' implementation/test.md
  feature_has_stage "$dir" "security-review" && printf '%s\n' security-review.md
  feature_has_stage "$dir" "review" && [[ "$(config_bool "gates" "require_review_before_commit" "true")" == "true" ]] && printf '%s\n' implementation/review.md
  feature_has_stage "$dir" "fix" && printf '%s\n' results/fix.md
}

replace_runtime_tokens() {
  local text="$1"
  local feature_name="$2"
  local feature_dir="$3"
  local stage_name="$4"
  text="${text//'{{FEATURE}}'/$feature_name}"
  text="${text//'{{FEATURE_DIR}}'/$feature_dir}"
  text="${text//'{{PROJECT_ROOT}}'/$PROJECT_ROOT}"
  text="${text//'{{STAGE}}'/$stage_name}"
  printf '%s' "$text"
}

completed_stage_for_gate_target() {
  local target="$1"
  case "$target" in
    plan) printf 'spec' ;;
    tasks) printf 'plan' ;;
    dispatch) printf 'tasks' ;;
    implement) printf 'dispatch' ;;
    test) printf 'implement' ;;
    review) printf 'test' ;;
    fix) printf 'review' ;;
    archive) printf 'fix' ;;
    *) printf '' ;;
  esac
}

run_stage_hooks() {
  local hook_timing="$1"
  local stage_name="$2"
  local feature_name="$3"
  local feature_dir="$4"
  local hook_key command rendered_command failure_policy hook_failed=0

  [[ -z "$stage_name" ]] && return
  [[ ! -f "$CONFIG" ]] && return

  hook_key="${hook_timing}_${stage_name}"
  failure_policy="$(config_string "runtime" "hook_failure_policy" "stop")"
  mkdir -p "$STATE_DIR"
  while IFS= read -r command; do
    [[ -z "$command" ]] && continue
    rendered_command="$(replace_runtime_tokens "$command" "$feature_name" "$feature_dir" "$stage_name")"
    printf 'Running hook %s: %s\n' "$hook_key" "$rendered_command"
    if ! (
      cd "$PROJECT_ROOT"
      sh -lc "$rendered_command"
    ); then
      hook_failed=1
      if [[ "$failure_policy" == "warn" ]]; then
        printf 'Hook failed but continuing due to runtime.hook_failure_policy=warn: %s\n' "$hook_key" >&2
      else
        printf 'Hook failed: %s\n' "$hook_key" >&2
        return 1
      fi
    fi
  done < <(yaml_list_under_section_key "hooks" "$hook_key" "$CONFIG" || true)

  if [[ "$hook_failed" -eq 1 && "$failure_policy" == "warn" ]]; then
    return 0
  fi
}

next_feature_id() {
  mkdir -p "$FEATURE_DIR"
  local last
  last="$(find "$FEATURE_DIR" -maxdepth 1 -type d -name 'FEATURE-[0-9][0-9][0-9]-*' 2>/dev/null | sed -E 's/.*FEATURE-([0-9]{3})-.*/\1/' | sort -n | tail -1 || true)"
  if [[ -z "$last" ]]; then
    printf '001'
  else
    printf '%03d' "$((10#$last + 1))"
  fi
}

render_template() {
  local src="$1"
  local dest="$2"
  local title="$3"
  local request="${4:-$title}"
  awk -v title="$title" -v request="$request" '
    function replace_all(line, token, value, out, i) {
      out = ""
      while ((i = index(line, token)) > 0) {
        out = out substr(line, 1, i - 1) value
        line = substr(line, i + length(token))
      }
      return out line
    }
    {
      line = replace_all($0, "{{FEATURE_TITLE}}", title)
      line = replace_all(line, "{{USER_REQUEST}}", request)
      print line
    }
  ' "$src" > "$dest"
}

model_profile_for_feature_type() {
  local type="$1"
  case "$type" in
    trivial) printf 'low' ;;
    bug|standard) printf 'medium' ;;
    major) printf 'high' ;;
    sensitive) printf 'extra-high' ;;
    *) printf 'medium' ;;
  esac
}

routing_reason_for_feature_type() {
  local type="$1"
  case "$type" in
    trivial) printf 'trivial feature: low-risk, small-scope work can use low reasoning unless task metadata says otherwise' ;;
    bug) printf 'bug feature: default to medium for diagnosis and verification, escalate sensitive fixes to high or extra-high' ;;
    standard) printf 'standard feature: default to medium for implementation and tests, escalate high-risk roles to high' ;;
    major) printf 'major feature: use high by default because scope and cross-module impact are higher' ;;
    sensitive) printf 'sensitive feature: use extra-high by default for security, user data, permissions, payment, or external module risk' ;;
    *) printf 'unknown feature type: default to medium until Manager assigns explicit routing metadata' ;;
  esac
}

render_feature_template() {
  local src="$1"
  local dest="$2"
  local title="$3"
  local request="${4:-$title}"
  local feature_type="${5:-standard}"
  local model_profile routing_reason
  model_profile="$(model_profile_for_feature_type "$feature_type")"
  routing_reason="$(routing_reason_for_feature_type "$feature_type")"
  awk -v title="$title" -v request="$request" -v feature_type="$feature_type" -v model_profile="$model_profile" -v routing_reason="$routing_reason" '
    function replace_all(line, token, value, out, i) {
      out = ""
      while ((i = index(line, token)) > 0) {
        out = out substr(line, 1, i - 1) value
        line = substr(line, i + length(token))
      }
      return out line
    }
    {
      line = replace_all($0, "{{FEATURE_TITLE}}", title)
      line = replace_all(line, "{{USER_REQUEST}}", request)
      line = replace_all(line, "{{FEATURE_TYPE}}", feature_type)
      line = replace_all(line, "{{MODEL_PROFILE}}", model_profile)
      line = replace_all(line, "{{ROUTING_REASON}}", routing_reason)
      print line
    }
  ' "$src" > "$dest"
}

render_vars() {
  local src="$1"
  local dest="$2"
  local task_id="$3"
  local role="$4"
  local summary="$5"
  local feature_dir="$6"
  awk -v task_id="$task_id" -v role="$role" -v summary="$summary" -v feature_dir="$feature_dir" '
    function replace_all(line, token, value, out, i) {
      out = ""
      while ((i = index(line, token)) > 0) {
        out = out substr(line, 1, i - 1) value
        line = substr(line, i + length(token))
      }
      return out line
    }
    {
      line = replace_all($0, "{{TASK_ID}}", task_id)
      line = replace_all(line, "{{ROLE}}", role)
      line = replace_all(line, "{{SUMMARY}}", summary)
      line = replace_all(line, "{{FEATURE_DIR}}", feature_dir)
      print line
    }
  ' "$src" > "$dest"
}

render_codex_prompt() {
  local dest="$1"
  local feature="$2"
  local task="$3"
  local role="$4"
  local model_profile="$5"
  local inputs="$6"
  local outputs="$7"
  awk -v feature="$feature" -v task="$task" -v role="$role" -v model_profile="$model_profile" -v inputs="$inputs" -v outputs="$outputs" '
    function replace_all(line, token, value, out, i) {
      out = ""
      while ((i = index(line, token)) > 0) {
        out = out substr(line, 1, i - 1) value
        line = substr(line, i + length(token))
      }
      return out line
    }
    {
      line = replace_all($0, "{{FEATURE}}", feature)
      line = replace_all(line, "{{TASK}}", task)
      line = replace_all(line, "{{ROLE}}", role)
      line = replace_all(line, "{{MODEL_PROFILE}}", model_profile)
      line = replace_all(line, "{{INPUTS}}", inputs)
      line = replace_all(line, "{{OUTPUTS}}", outputs)
      print line
    }
  ' "$TEMPLATE_DIR/adapters/codex-dispatch-prompt.md" > "$dest"
}

codex_reasoning_config_for_profile() {
  local profile="$1"
  case "$profile" in
    low|medium|high|extra-high) printf 'model_reasoning_effort="%s"' "$profile" ;;
    *) printf 'model_reasoning_effort="medium"' ;;
  esac
}

dispatch_plan_dir() {
  local task_id="$1"
  printf '%s/records/dispatch/%s_codex_plan' "$DOCS_DIR" "$task_id"
}

stage_plan_dir() {
  local task_id="$1"
  local stage="$2"
  printf '%s/records/dispatch/%s_codex_stage_%s' "$DOCS_DIR" "$task_id" "$stage"
}

parse_dispatch_rows() {
  local dispatch_file="$1"
  awk -F'|' '
    /^\|/ {
      task = $2
      role = $3
      profile = $4
      inputs = $5
      outputs = $6
      status = $7
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", task)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", role)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", profile)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", inputs)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", outputs)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", status)
      if (task == "Task" || task ~ /^---/ || task == "") next
      print task "\t" role "\t" profile "\t" inputs "\t" outputs "\t" status
    }
  ' "$dispatch_file"
}

parse_stage_routing_row() {
  local routing_file="$1"
  local target_stage="$2"
  awk -F'|' -v target="$target_stage" '
    /^\|/ {
      stage = $2
      role = $3
      complexity = $4
      risk = $5
      profile = $6
      inputs = $7
      outputs = $8
      reason = $9
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", stage)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", role)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", profile)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", inputs)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", outputs)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", reason)
      if (stage == target) {
        print stage "\t" role "\t" profile "\t" inputs "\t" outputs "\t" reason
        found = 1
        exit
      }
    }
    END { exit found ? 0 : 1 }
  ' "$routing_file"
}

stage_codex_plan() {
  local feature="$1"
  local stage="$2"
  local dir title task_id plan_dir script plan_file prompt_file row parsed_stage role profile inputs outputs reason config_arg
  dir="$(feature_path "$feature")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  load_project_paths

  if [[ ! -f "$dir/model-routing.md" ]]; then
    printf 'Missing model routing file: %s\n' "$dir/model-routing.md" >&2
    return 1
  fi

  row="$(parse_stage_routing_row "$dir/model-routing.md" "$stage" || true)"
  if [[ -z "$row" ]]; then
    printf 'No stage routing row for stage %s in %s\n' "$stage" "$dir/model-routing.md" >&2
    return 1
  fi

  IFS=$'\t' read -r parsed_stage role profile inputs outputs reason <<< "$row"
  plan_dir="$(stage_plan_dir "$task_id" "$stage")"
  mkdir -p "$plan_dir"
  script="$plan_dir/run-codex-stage.sh"
  plan_file="$plan_dir/plan.md"
  prompt_file="$plan_dir/01-$(slugify "$stage").md"
  config_arg="$(codex_reasoning_config_for_profile "$profile")"

  render_codex_prompt "$prompt_file" "$title" "$stage" "$role" "$profile" "$inputs" "$outputs"

  {
    printf '# Codex Stage Plan: %s / %s\n\n' "$title" "$stage"
    printf 'Generated from `%s`.\n\n' "$dir/model-routing.md"
    printf '| Stage | Role | Model Profile | Prompt | Command |\n'
    printf '| --- | --- | --- | --- | --- |\n'
    printf '| %s | %s | %s | %s | `codex exec -C %s -c %s - < %s` |\n' \
      "$stage" "$role" "$profile" "$prompt_file" "$PROJECT_ROOT" "$config_arg" "$prompt_file"
  } > "$plan_file"

  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n\n'
    printf 'cd %q\n\n' "$PROJECT_ROOT"
    printf 'codex exec -C %q -c %q - < %q\n' "$PROJECT_ROOT" "$config_arg" "$prompt_file"
  } > "$script"
  chmod +x "$script"

  printf 'Wrote Codex stage plan: %s\n' "$plan_file"
  printf 'Wrote Codex stage script: %s\n' "$script"
}

stage_codex_run() {
  local feature="$1"
  local stage="$2"
  local execute="$3"
  local dir title task_id script
  dir="$(feature_path "$feature")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  script="$(stage_plan_dir "$task_id" "$stage")/run-codex-stage.sh"

  if [[ ! -f "$script" ]]; then
    stage_codex_plan "$feature" "$stage"
  fi

  if [[ "$execute" == "true" ]]; then
    printf 'Executing Codex stage script: %s\n' "$script"
    "$script"
  else
    printf 'Dry run. Review and execute with:\n'
    printf '  %s\n' "$script"
    printf 'or run: agentflow stage run %s --stage %s --adapter codex --execute\n' "$title" "$stage"
  fi
}

dispatch_codex_plan() {
  local feature="$1"
  local dir title task_id plan_dir script plan_file prompt_file task role profile inputs outputs status idx config_arg
  dir="$(feature_path "$feature")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  load_project_paths

  if [[ ! -f "$dir/dispatch.md" ]]; then
    printf 'Missing dispatch file: %s\n' "$dir/dispatch.md" >&2
    return 1
  fi

  plan_dir="$(dispatch_plan_dir "$task_id")"
  mkdir -p "$plan_dir"
  script="$plan_dir/run-codex-dispatch.sh"
  plan_file="$plan_dir/plan.md"
  idx=0

  {
    printf '# Codex Dispatch Plan: %s\n\n' "$title"
    printf 'Generated from `%s`.\n\n' "$dir/dispatch.md"
    printf '| ID | Task | Role | Model Profile | Prompt | Command |\n'
    printf '| --- | --- | --- | --- | --- | --- |\n'
  } > "$plan_file"

  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n\n'
    printf 'cd %q\n\n' "$PROJECT_ROOT"
  } > "$script"

  while IFS=$'\t' read -r task role profile inputs outputs status; do
    idx=$((idx + 1))
    prompt_file="$plan_dir/$(printf '%02d' "$idx")-$(slugify "$task").md"
    config_arg="$(codex_reasoning_config_for_profile "$profile")"
    render_codex_prompt "$prompt_file" "$title" "$task" "$role" "$profile" "$inputs" "$outputs"
    printf '| %02d | %s | %s | %s | %s | `codex exec -C %s -c %s - < %s` |\n' \
      "$idx" "$task" "$role" "$profile" "$prompt_file" "$PROJECT_ROOT" "$config_arg" "$prompt_file" >> "$plan_file"
    printf 'codex exec -C %q -c %q - < %q\n' "$PROJECT_ROOT" "$config_arg" "$prompt_file" >> "$script"
  done < <(parse_dispatch_rows "$dir/dispatch.md")

  chmod +x "$script"
  printf 'Wrote Codex dispatch plan: %s\n' "$plan_file"
  printf 'Wrote Codex dispatch script: %s\n' "$script"
}

dispatch_codex_run() {
  local feature="$1"
  local execute="$2"
  local dir title task_id script
  dir="$(feature_path "$feature")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  script="$(dispatch_plan_dir "$task_id")/run-codex-dispatch.sh"

  if [[ ! -f "$script" ]]; then
    dispatch_codex_plan "$feature"
  fi

  if [[ "$execute" == "true" ]]; then
    printf 'Executing Codex dispatch script: %s\n' "$script"
    "$script"
  else
    printf 'Dry run. Review and execute with:\n'
    printf '  %s\n' "$script"
    printf 'or run: agentflow dispatch run %s --adapter codex --execute\n' "$title"
  fi
}

state_features_file() {
  load_project_paths
  printf '%s/features.yml' "$STATE_DIR"
}

task_board_header() {
  cat <<'HEADER'
<!--
GENERATED FILE: DO NOT EDIT DIRECTLY.

Source of truth:
- features/FEATURE-XXX/state.yml

To update:
- agentflow feature next FEATURE-XXX
- agentflow feature status FEATURE-XXX
- agentflow board render
-->

HEADER
}

yaml_quote() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/^/"/; s/$/"/'
}

modules_registry_file() {
  printf '%s/external_modules.yml' "$MODULES_DIR"
}

modules_policy_file() {
  printf '%s/external_module_policy.yml' "$MODULES_DIR"
}

ensure_modules_state() {
  mkdir -p "$MODULES_DIR"
  if [[ ! -f "$(modules_registry_file)" ]]; then
    cp "$TEMPLATE_DIR/modules/external_modules.yml" "$(modules_registry_file)"
  fi
  if [[ ! -f "$(modules_policy_file)" ]]; then
    cp "$TEMPLATE_DIR/modules/external_module_policy.yml" "$(modules_policy_file)"
  fi
}

clean_yaml_scalar() {
  sed -E 's/^[^:]+:[[:space:]]*//; s/^"//; s/"$//'
}

valid_usage_mode() {
  case "$1" in
    reference-only|dependency|vendor|direct-copy) return 0 ;;
    *) return 1 ;;
  esac
}

is_critical_domain() {
  case "$1" in
    auth|user|permission|payment|crypto|file-upload|admin-account|tenant-isolation) return 0 ;;
    *) return 1 ;;
  esac
}

feature_mentions_sensitive_domain() {
  local text="$1"
  printf '%s' "$text" | grep -Eiq 'auth|login|user|permission|role|payment|crypto|file[ -]?upload|admin|tenant|token|password'
}

module_exists() {
  local module_id="$1"
  ensure_modules_state
  awk -v target="$module_id" '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ {
      if (clean($0) == target) found = 1
    }
    END { exit found ? 0 : 1 }
  ' "$(modules_registry_file)"
}

module_field_value() {
  local module_id="$1"
  local key="$2"
  ensure_modules_state
  awk -v target="$module_id" -v key="$key" '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ {
      in_target = (clean($0) == target)
      next
    }
    in_target && $0 ~ "^    " key ":" {
      print clean($0)
      exit
    }
  ' "$(modules_registry_file)"
}

module_list_values() {
  local module_id="$1"
  local key="$2"
  ensure_modules_state
  awk -v target="$module_id" -v key="$key" '
    function clean_item(value) {
      sub(/^[[:space:]]*-[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ {
      in_target = (clean($0) == target)
      in_list = 0
      next
    }
    in_target && $0 ~ "^    " key ":" {
      in_list = 1
      next
    }
    in_target && in_list && $0 ~ /^      - / {
      print clean_item($0)
      next
    }
    in_target && in_list && $0 ~ /^    [A-Za-z0-9_-]+:/ {
      exit
    }
  ' "$(modules_registry_file)"
}

module_requested_mode() {
  local module_id="$1"
  local requested approved first_allowed
  requested="$(module_field_value "$module_id" "requested_mode")"
  approved="$(module_field_value "$module_id" "approved_mode")"
  first_allowed="$(module_list_values "$module_id" "allowed_modes" | head -1)"
  printf '%s' "${requested:-${approved:-$first_allowed}}"
}

print_module_block() {
  local module_id="$1"
  ensure_modules_state
  awk -v target="$module_id" '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ {
      if (printing) exit
      printing = (clean($0) == target)
    }
    printing { print }
  ' "$(modules_registry_file)"
}

module_list() {
  ensure_modules_state
  printf '| ID | Name | Source Type | Module Type | Domain | Risk | Status | Allowed Modes |\n'
  printf '| --- | --- | --- | --- | --- | --- | --- | --- |\n'
  awk '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    function flush() {
      if (id == "") return
      printf("| %s | %s | %s | %s | %s | %s | %s | %s |\n",
        id, name, source_type, module_type, domain, risk_level, status, allowed_modes)
    }
    /^  - id:/ {
      flush()
      id = clean($0)
      name = source_type = module_type = domain = risk_level = status = allowed_modes = ""
      in_allowed = 0
      next
    }
    /^[[:space:]]+name:/ { name = clean($0); next }
    /^[[:space:]]+source_type:/ { source_type = clean($0); next }
    /^[[:space:]]+module_type:/ { module_type = clean($0); next }
    /^[[:space:]]+domain:/ { domain = clean($0); next }
    /^[[:space:]]+risk_level:/ { risk_level = clean($0); next }
    /^[[:space:]]+status:/ { status = clean($0); next }
    /^[[:space:]]+allowed_modes:/ { in_allowed = 1; next }
    in_allowed && /^[[:space:]]+- / {
      item = $0
      sub(/^[[:space:]]*-[[:space:]]*/, "", item)
      allowed_modes = allowed_modes == "" ? item : allowed_modes "," item
      next
    }
    in_allowed && /^[[:space:]]+[A-Za-z0-9_-]+:/ { in_allowed = 0 }
    END { flush() }
  ' "$(modules_registry_file)"
}

module_show() {
  local module_id="$1"
  if ! module_exists "$module_id"; then
    printf 'Unknown module: %s\n' "$module_id" >&2
    exit 1
  fi
  print_module_block "$module_id"
}

module_add() {
  local module_id="$1"
  shift || true
  local name="" source_type="" source="" module_type="" domain="" risk="" mode="" allowed_mode forbidden_vendor="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --source-type) source_type="$2"; shift 2 ;;
      --source) source="$2"; shift 2 ;;
      --module-type) module_type="$2"; shift 2 ;;
      --domain) domain="$2"; shift 2 ;;
      --risk) risk="$2"; shift 2 ;;
      --mode) mode="$2"; shift 2 ;;
      *)
        printf 'Unknown module add option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done

  [[ -n "$module_id" && -n "$name" && -n "$source_type" && -n "$source" && -n "$module_type" && -n "$domain" && -n "$risk" && -n "$mode" ]] || {
    printf 'Missing required module add fields\n' >&2
    exit 1
  }
  valid_usage_mode "$mode" || { printf 'Unsupported usage mode: %s\n' "$mode" >&2; exit 1; }
  ensure_modules_state
  if module_exists "$module_id"; then
    printf 'Module already exists: %s\n' "$module_id"
    printf 'Keeping existing registration. Use module show to inspect it.\n'
    return
  fi

  allowed_mode="$mode"
  if [[ "$source_type" == "public" ]] && is_critical_domain "$domain"; then
    allowed_mode="reference-only"
    if [[ "$mode" == "vendor" || "$mode" == "direct-copy" ]]; then
      printf 'WARNING: public + critical domain defaults to reference-only; requested mode %s requires approval or is blocked by policy.\n' "$mode" >&2
    fi
  elif [[ "$source_type" == "public" && "$mode" == "direct-copy" ]]; then
    allowed_mode="reference-only"
    printf 'WARNING: public direct-copy is blocked by default; storing module as reference-only candidate.\n' >&2
  fi

  {
    printf '\n'
    printf '  - id: %s\n' "$module_id"
    printf '    name: %s\n' "$name"
    printf '    source_type: %s\n' "$source_type"
    printf '    source: %s\n' "$source"
    printf '    module_type: %s\n' "$module_type"
    printf '    domain: %s\n' "$domain"
    printf '    risk_level: %s\n' "$risk"
    printf '    status: candidate\n'
    printf '    requested_mode: %s\n' "$mode"
    printf '    allowed_modes:\n'
    printf '      - %s\n' "$allowed_mode"
    printf '    forbidden_modes:\n'
    [[ "$allowed_mode" != "vendor" ]] && printf '      - vendor\n'
    printf '      - direct-copy\n'
    printf '    notes:\n'
    printf '      - Registered by agentflow module add\n'
    printf '      - No source was downloaded or copied\n'
  } >> "$(modules_registry_file)"

  printf 'Registered module: %s\n' "$module_id"
}

module_contract() {
  local module_id="$1"
  local dir contract security integration
  if ! module_exists "$module_id"; then
    printf 'Unknown module: %s\n' "$module_id" >&2
    exit 1
  fi
  dir="$MODULES_DIR/$module_id"
  mkdir -p "$dir"
  contract="$dir/module-contract.yml"
  security="$dir/security-notes.md"
  integration="$dir/integration-notes.md"
  {
    printf 'id: %s\n' "$module_id"
    printf 'name: %s\n' "$(module_field_value "$module_id" "name")"
    printf 'source: %s\n' "$(module_field_value "$module_id" "source")"
    printf 'source_type: %s\n' "$(module_field_value "$module_id" "source_type")"
    printf 'module_type: %s\n' "$(module_field_value "$module_id" "module_type")"
    printf 'domain: %s\n' "$(module_field_value "$module_id" "domain")"
    printf 'risk_level: %s\n' "$(module_field_value "$module_id" "risk_level")"
    printf 'status: %s\n\n' "$(module_field_value "$module_id" "status")"
    printf 'capabilities:\n  - TBD\n\n'
    printf 'public_contract:\n'
    printf '  api:\n    - TBD\n'
    printf '  routes:\n    - TBD\n'
    printf '  concepts:\n    - TBD\n\n'
    printf 'allowed_usage:\n'
    module_list_values "$module_id" "allowed_modes" | sed 's/^/  - /'
    printf '\nforbidden_usage:\n'
    module_list_values "$module_id" "forbidden_modes" | sed 's/^/  - /'
    printf '\nsecurity_notes:\n  - TBD\n\n'
    printf 'integration_notes:\n  - TBD\n'
  } > "$contract"
  {
    printf '# Security Notes: %s\n\n' "$module_id"
    printf 'No remote repository was downloaded or scanned by AgentFlow.\n\n'
    printf '## Required Checks\n\n'
    printf -- '- License check: TBD\n'
    printf -- '- Maintenance check: TBD\n'
    printf -- '- Sensitive domain review: TBD\n'
  } > "$security"
  {
    printf '# Integration Notes: %s\n\n' "$module_id"
    printf 'Document version lock, import boundary, adapter code, and replacement plan before using this module beyond reference-only.\n\n'
    printf '## Notes\n\n- TBD\n'
  } > "$integration"
  printf 'Generated module contract files:\n'
  printf '  %s\n' "$contract"
  printf '  %s\n' "$security"
  printf '  %s\n' "$integration"
}

rewrite_module_status() {
  local module_id="$1"
  local mode="$2"
  local approved_by="$3"
  local approved_at="$4"
  local registry tmp_file
  registry="$(modules_registry_file)"
  tmp_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-modules.XXXXXX")"
  awk -v target="$module_id" -v mode="$mode" -v approved_by="$approved_by" -v approved_at="$approved_at" '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ {
      in_target = (clean($0) == target)
      print
      next
    }
    in_target && /^    status:/ { print "    status: approved"; next }
    in_target && /^    approved_mode:/ { next }
    in_target && /^    approved_by:/ { next }
    in_target && /^    approved_at:/ { next }
    in_target && /^    notes:/ {
        print "    approved_mode: " mode
        print "    approved_by: " approved_by
        print "    approved_at: " approved_at
        print
        next
    }
    {
      print
    }
  ' "$registry" > "$tmp_file"
  mv "$tmp_file" "$registry"
}

module_approve() {
  local module_id="$1"
  shift || true
  local mode="" human_approved="false" approved_by="local-user" source_type domain risk approved_at
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode) mode="$2"; shift 2 ;;
      --human-approved) human_approved="true"; shift ;;
      --approved-by) approved_by="$2"; shift 2 ;;
      *)
        printf 'Unknown module approve option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done
  [[ -n "$mode" ]] || { printf 'Missing --mode for module approve\n' >&2; exit 1; }
  valid_usage_mode "$mode" || { printf 'Unsupported usage mode: %s\n' "$mode" >&2; exit 1; }
  module_exists "$module_id" || { printf 'Unknown module: %s\n' "$module_id" >&2; exit 1; }

  source_type="$(module_field_value "$module_id" "source_type")"
  domain="$(module_field_value "$module_id" "domain")"
  risk="$(module_field_value "$module_id" "risk_level")"

  if [[ "$source_type" == "public" && "$mode" == "direct-copy" ]]; then
    printf 'BLOCKED: public modules cannot be approved for direct-copy.\n' >&2
    exit 1
  fi
  if [[ "$source_type" == "public" ]] && is_critical_domain "$domain" && [[ "$mode" == "vendor" ]]; then
    printf 'BLOCKED: public + critical domain + vendor is blocked by default. Use reference-only or an internal/trusted module.\n' >&2
    exit 1
  fi
  if [[ "$source_type" == "public" && "$mode" == "vendor" && ( "$risk" == "high" || "$risk" == "critical" ) && "$human_approved" != "true" ]]; then
    printf 'BLOCKED: public high/critical vendor requires --human-approved.\n' >&2
    exit 1
  fi
  if [[ "$source_type" == "internal" && "$mode" == "vendor" ]]; then
    printf 'WARNING: internal vendor approval requires version_lock and integration_notes.\n' >&2
  fi

  approved_at="$(date +%Y-%m-%dT%H:%M:%S%z)"
  rewrite_module_status "$module_id" "$mode" "$approved_by" "$approved_at"
  printf 'Approved module %s for mode %s by %s\n' "$module_id" "$mode" "$approved_by"
}

module_ids() {
  ensure_modules_state
  awk '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    /^  - id:/ { print clean($0) }
  ' "$(modules_registry_file)"
}

feature_text_for_reuse() {
  local dir="$1"
  {
    basename "$dir"
    [[ -f "$dir/spec.md" ]] && cat "$dir/spec.md"
    [[ -f "$dir/plan.md" ]] && cat "$dir/plan.md"
    [[ -f "$dir/tasks.md" ]] && cat "$dir/tasks.md"
  } 2>/dev/null
}

module_matches_feature() {
  local module_id="$1"
  local feature_text="$2"
  local domain module_type name
  domain="$(module_field_value "$module_id" "domain")"
  module_type="$(module_field_value "$module_id" "module_type")"
  name="$(module_field_value "$module_id" "name")"
  if printf '%s' "$feature_text" | grep -Eiq "$domain|$module_type|$module_id|$name"; then
    return 0
  fi
  if feature_mentions_sensitive_domain "$feature_text" && is_critical_domain "$domain"; then
    return 0
  fi
  if printf '%s' "$feature_text" | grep -Eiq 'admin' && [[ "$domain" == "admin" ]]; then
    return 0
  fi
  return 1
}

recommended_mode_for_module() {
  local module_id="$1"
  local source_type domain risk
  source_type="$(module_field_value "$module_id" "source_type")"
  domain="$(module_field_value "$module_id" "domain")"
  risk="$(module_field_value "$module_id" "risk_level")"
  if [[ "$source_type" == "public" ]] && { is_critical_domain "$domain" || [[ "$risk" == "high" || "$risk" == "critical" ]]; }; then
    printf 'reference-only'
  else
    module_list_values "$module_id" "allowed_modes" | head -1
  fi
}

reuse_analyze() {
  local feature="$1"
  local dir feature_name feature_text analysis risk_file module_id matched=0 sensitive_domains=""
  dir="$(feature_path "$feature")"
  feature_name="$(basename "$dir")"
  ensure_modules_state
  feature_text="$(feature_text_for_reuse "$dir")"
  analysis="$dir/reuse-analysis.md"
  risk_file="$dir/external-module-risk.md"

  {
    printf '# Reuse Analysis\n\n'
    printf 'Feature: %s\n\n' "$feature_name"
    printf '## Status\n\nStatus: complete\n\n'
    printf '## Candidate Modules\n\n'
    while IFS= read -r module_id; do
      [[ -z "$module_id" ]] && continue
      if module_matches_feature "$module_id" "$feature_text"; then
        matched=1
        printf '### %s\n\n' "$module_id"
        printf -- '- Source Type: %s\n' "$(module_field_value "$module_id" "source_type")"
        printf -- '- Module Type: %s\n' "$(module_field_value "$module_id" "module_type")"
        printf -- '- Domain: %s\n' "$(module_field_value "$module_id" "domain")"
        printf -- '- Risk Level: %s\n' "$(module_field_value "$module_id" "risk_level")"
        printf -- '- Recommended Mode: %s\n' "$(recommended_mode_for_module "$module_id")"
        printf -- '- Requested Mode: %s\n' "$(module_requested_mode "$module_id")"
        printf -- '- Reason:\n'
        printf '  - This feature appears related to `%s` or nearby sensitive concepts.\n' "$(module_field_value "$module_id" "domain")"
        printf '  - Public code should not be directly copied.\n\n'
      fi
    done < <(module_ids)
    if [[ "$matched" -eq 0 ]]; then
      printf 'No registered candidate modules matched this feature.\n\n'
    fi
    printf '## Decision\n\n'
    printf -- '- Use matching public modules as reference-only unless an explicit approval allows another mode.\n'
    printf -- '- Do not vendor authentication, permission, payment, token, password, or role-check logic from public repositories.\n'
    printf -- '- Human approval required before using any public high-risk module as dependency or vendor.\n'
  } > "$analysis"

  {
    printf '# External Module Risk\n\n'
    printf 'Feature: %s\n\n' "$feature_name"
    printf '## Status\n\nStatus: complete\n\n'
    printf '## Risk Summary\n\n'
    if feature_mentions_sensitive_domain "$feature_text"; then
      printf 'This feature may involve sensitive domains:\n\n'
      printf -- '- user\n'
      printf -- '- permission\n'
      printf -- '- admin-account\n'
      printf -- '- auth/login/token/password, if present in implementation scope\n\n'
      printf 'human_approval_required: true\n\n'
    else
      printf 'No sensitive domain keywords were detected in the current feature text.\n\n'
      printf 'human_approval_required: false\n\n'
    fi
    printf '## Policy\n\n'
    printf 'Public modules in sensitive domains are reference-only by default.\n\n'
    printf '## Blocked Actions\n\n'
    printf -- '- direct-copy public auth code\n'
    printf -- '- vendor public permission module without human approval\n'
    printf -- '- copy token / password / role-check logic from public repositories\n'
  } > "$risk_file"

  printf 'Wrote reuse analysis: %s\n' "$analysis"
  printf 'Wrote external module risk: %s\n' "$risk_file"
}

analysis_references_module() {
  local analysis="$1"
  local module_id="$2"
  grep -Eq "^###[[:space:]]+$module_id$" "$analysis"
}

reuse_gate_check() {
  local feature="$1"
  local dir feature_name analysis risk_file feature_text module_id failed=0
  local source_type domain risk requested_mode approved_mode status contract integration
  dir="$(feature_path "$feature")"
  feature_name="$(basename "$dir")"
  analysis="$dir/reuse-analysis.md"
  risk_file="$dir/external-module-risk.md"
  ensure_modules_state

  if [[ ! -f "$analysis" ]]; then
    printf 'BLOCKED: missing reuse analysis: %s\n' "$analysis" >&2
    return 1
  fi
  if [[ ! -f "$risk_file" ]]; then
    printf 'BLOCKED: missing external module risk file: %s\n' "$risk_file" >&2
    return 1
  fi

  feature_text="$(feature_text_for_reuse "$dir")"
  if feature_mentions_sensitive_domain "$feature_text" && ! grep -Eq '^human_approval_required:[[:space:]]*true' "$risk_file"; then
    printf 'BLOCKED: sensitive feature requires human_approval_required: true in external-module-risk.md\n' >&2
    failed=1
  fi

  while IFS= read -r module_id; do
    [[ -z "$module_id" ]] && continue
    analysis_references_module "$analysis" "$module_id" || continue
    source_type="$(module_field_value "$module_id" "source_type")"
    domain="$(module_field_value "$module_id" "domain")"
    risk="$(module_field_value "$module_id" "risk_level")"
    requested_mode="$(module_requested_mode "$module_id")"
    approved_mode="$(module_field_value "$module_id" "approved_mode")"
    status="$(module_field_value "$module_id" "status")"
    contract="$MODULES_DIR/$module_id/module-contract.yml"
    integration="$MODULES_DIR/$module_id/integration-notes.md"

    if [[ "$source_type" == "public" && "$requested_mode" == "direct-copy" ]]; then
      printf 'BLOCKED: public module %s requested direct-copy, which is forbidden.\n' "$module_id" >&2
      failed=1
    fi
    if [[ "$source_type" == "public" ]] && is_critical_domain "$domain" && [[ "$requested_mode" != "reference-only" ]]; then
      printf 'BLOCKED: public module %s is critical risk. domain=%s requested_mode=%s allowed=reference-only.\n' "$module_id" "$domain" "$requested_mode" >&2
      failed=1
    fi
    if [[ "$source_type" == "public" && "$requested_mode" == "vendor" && ( "$risk" == "high" || "$risk" == "critical" ) && "$status" != "approved" ]]; then
      printf 'BLOCKED: public high/critical vendor module %s requires human approval.\n' "$module_id" >&2
      failed=1
    fi
    if [[ "$source_type" == "public" && "$requested_mode" == "vendor" && ( "$risk" == "high" || "$risk" == "critical" ) && "$approved_mode" != "vendor" ]]; then
      printf 'BLOCKED: module %s is not approved for vendor mode.\n' "$module_id" >&2
      failed=1
    fi
    if [[ "$source_type" == "internal" && "$status" == "approved" ]]; then
      if [[ ! -f "$contract" || ! -f "$integration" ]]; then
        printf 'WARNING: approved internal module %s should still document version lock and integration notes.\n' "$module_id" >&2
      fi
    elif [[ "$source_type" == "public" || "$requested_mode" != "reference-only" ]]; then
      if [[ ! -f "$contract" ]]; then
        printf 'BLOCKED: missing module contract for %s: %s\n' "$module_id" "$contract" >&2
        failed=1
      fi
      if [[ ! -f "$integration" ]]; then
        printf 'BLOCKED: missing integration notes for %s: %s\n' "$module_id" "$integration" >&2
        failed=1
      fi
    fi
  done < <(module_ids)

  if [[ "$failed" -eq 0 ]]; then
    printf 'PASS: reuse gate passed for %s\n' "$feature_name"
    return 0
  fi
  return 1
}

reuse_gate() {
  reuse_gate_check "$1"
}

ensure_features_state() {
  local state_file
  state_file="$(state_features_file)"
  mkdir -p "$(dirname "$state_file")"
  if [[ ! -f "$state_file" ]]; then
    printf 'features:\n' > "$state_file"
  fi
}

acquire_state_lock() {
  local lock_dir="$STATE_DIR/lock"
  local waited=0
  mkdir -p "$STATE_DIR"
  while ! mkdir "$lock_dir" 2>/dev/null; do
    waited=$((waited + 1))
    if [[ "$waited" -gt 100 ]]; then
      printf 'Timed out waiting for AgentFlow state lock: %s\n' "$lock_dir" >&2
      exit 1
    fi
    sleep 0.1
  done
}

release_state_lock() {
  rmdir "$STATE_DIR/lock" 2>/dev/null || true
}

upsert_feature_state() {
  local id="$1"
  local title="$2"
  local stage="$3"
  local status="$4"
  local owner="${5:-Manager}"
  local mode="${6:-subagent}"
  local verified="${7:-no}"
  local notes="${8:-}"
  local type="${9:-}"
  local dir state_file updated_at
  load_project_paths
  dir="$FEATURE_DIR/$id"
  mkdir -p "$dir"
  state_file="$(feature_state_file_for_dir "$dir")"
  updated_at="$(date +%F)"
  if [[ -z "$type" ]]; then
    type="$(feature_state_value "$dir" "type")"
  fi
  type="${type:-$(default_feature_type)}"

  {
    printf 'id: %s\n' "$(yaml_quote "$id")"
    printf 'title: %s\n' "$(yaml_quote "$title")"
    printf 'type: %s\n' "$(yaml_quote "$type")"
    printf 'stage: %s\n' "$(yaml_quote "$stage")"
    printf 'status: %s\n' "$(yaml_quote "$status")"
    printf 'mode: %s\n' "$(yaml_quote "$mode")"
    printf 'owner: %s\n' "$(yaml_quote "$owner")"
    printf 'verified: %s\n' "$(yaml_quote "$verified")"
    printf 'notes: %s\n' "$(yaml_quote "$notes")"
    printf 'updated_at: %s\n' "$(yaml_quote "$updated_at")"
  } > "$state_file"
}

render_task_board() {
  local board tmp_file feature_dir id title type stage mode owner status verified notes
  load_project_paths
  ensure_features_state
  mkdir -p "$DOCS_DIR"
  board="$DOCS_DIR/03_TASK_BOARD.md"
  tmp_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-board.XXXXXX")"

  {
    task_board_header
    printf '# Task Board\n\n'
    printf '| ID | Feature | Type | Stage | Mode | Owner | Status | Verified | Notes |\n'
    printf '| --- | --- | --- | --- | --- | --- | --- | --- | --- |\n'
    while IFS= read -r feature_dir; do
      [[ -f "$feature_dir/state.yml" ]] || continue
      id="$(feature_state_value "$feature_dir" "id")"
      title="$(feature_state_value "$feature_dir" "title")"
      type="$(feature_state_value "$feature_dir" "type")"
      stage="$(feature_state_value "$feature_dir" "stage")"
      mode="$(feature_state_value "$feature_dir" "mode")"
      owner="$(feature_state_value "$feature_dir" "owner")"
      status="$(feature_state_value "$feature_dir" "status")"
      verified="$(feature_state_value "$feature_dir" "verified")"
      notes="$(feature_state_value "$feature_dir" "notes")"
      id="${id:-$(basename "$feature_dir")}"
      title="${title:-$id}"
      type="${type:-major}"
      stage="${stage:-draft}"
      mode="${mode:-subagent}"
      owner="${owner:-Manager}"
      status="${status:-pending}"
      verified="${verified:-no}"
      notes="${notes//|/\\|}"
      printf '| %s | %s | %s | %s | %s | %s | %s | %s | %s |\n' "$id" "$title" "$type" "$stage" "$mode" "$owner" "$status" "$verified" "$notes"
    done < <(find "$FEATURE_DIR" -maxdepth 1 -type d -name 'FEATURE-[0-9][0-9][0-9]-*' 2>/dev/null | sort)
  } > "$tmp_file"

  mv "$tmp_file" "$board"
  printf 'Rendered task board from state: %s\n' "$board"
}

migrate_feature_state() {
  local state_file tmp_file migrated=0 skipped=0 line
  load_project_paths
  state_file="$(state_features_file)"
  if [[ ! -f "$state_file" ]]; then
    printf 'No legacy global state found: %s\n' "$state_file"
    return
  fi

  tmp_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-state-migrate.XXXXXX")"
  awk '
    function clean(value) {
      sub(/^[^:]+:[[:space:]]*/, "", value)
      gsub(/^"/, "", value)
      gsub(/"$/, "", value)
      return value
    }
    function flush() {
      if (id == "") return
      printf("%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", id, title, stage, status, mode, owner, verified, notes)
    }
    /^  - id:/ {
      flush()
      id = clean($0)
      title = stage = status = mode = owner = verified = notes = ""
      next
    }
    /^[[:space:]]+title:/ { title = clean($0); next }
    /^[[:space:]]+stage:/ { stage = clean($0); next }
    /^[[:space:]]+status:/ { status = clean($0); next }
    /^[[:space:]]+mode:/ { mode = clean($0); next }
    /^[[:space:]]+owner:/ { owner = clean($0); next }
    /^[[:space:]]+verified:/ { verified = clean($0); next }
    /^[[:space:]]+notes:/ { notes = clean($0); next }
    END { flush() }
  ' "$state_file" > "$tmp_file"

  while IFS=$'\t' read -r id title stage status mode owner verified notes; do
    [[ -z "$id" ]] && continue
    if [[ ! -d "$FEATURE_DIR/$id" ]]; then
      printf 'Skip missing feature directory: %s\n' "$FEATURE_DIR/$id" >&2
      skipped=$((skipped + 1))
      continue
    fi
    if [[ -f "$FEATURE_DIR/$id/state.yml" ]]; then
      printf 'Skip existing feature state: %s/state.yml\n' "$FEATURE_DIR/$id"
      skipped=$((skipped + 1))
      continue
    fi
    upsert_feature_state "$id" "${title:-$id}" "${stage:-draft}" "${status:-pending}" "${owner:-Manager}" "${mode:-subagent}" "${verified:-no}" "${notes:-Migrated from .agentflow/state/features.yml}" "major"
    printf 'Migrated feature state: %s/state.yml\n' "$FEATURE_DIR/$id"
    migrated=$((migrated + 1))
  done < "$tmp_file"
  rm -f "$tmp_file"

  render_task_board
  printf 'State migration complete: %s migrated, %s skipped\n' "$migrated" "$skipped"
}

check_task_board_generated_header() {
  local board
  load_project_paths
  board="$DOCS_DIR/03_TASK_BOARD.md"
  if [[ ! -f "$board" ]]; then
    printf 'Missing generated task board: %s\n' "$board" >&2
    return 1
  fi
  if ! sed -n '1,12p' "$board" | grep -Fq 'GENERATED FILE: DO NOT EDIT DIRECTLY.'; then
    printf 'Task board is missing generated-file header: %s\n' "$board" >&2
    return 1
  fi
}

check_task_board_fresh() {
  local board before_file after_file had_board=0
  load_project_paths
  board="$DOCS_DIR/03_TASK_BOARD.md"
  before_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-board-before.XXXXXX")"
  after_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-board-after.XXXXXX")"
  if [[ -f "$board" ]]; then
    cp "$board" "$before_file"
    had_board=1
  fi
  render_task_board >/dev/null
  cp "$board" "$after_file"
  if [[ "$had_board" -eq 1 ]]; then
    mv "$before_file" "$board"
  else
    rm -f "$board"
  fi
  if [[ "$had_board" -eq 1 ]] && cmp -s "$board" "$after_file"; then
    rm -f "$after_file"
    printf 'Task board is up to date: %s\n' "$board"
  else
    rm -f "$after_file" "$before_file"
    printf 'Task board is not up to date. Run: agentflow board render\n' >&2
    return 1
  fi
}

check_all_features() {
  local feature_dir failed=0
  load_project_paths
  check_task_board_generated_header || failed=1
  check_task_board_fresh || failed=1
  while IFS= read -r feature_dir; do
    [[ -d "$feature_dir" ]] || continue
    if ! check_feature_health "$feature_dir"; then
      failed=1
    fi
  done < <(find "$FEATURE_DIR" -maxdepth 1 -type d -name 'FEATURE-[0-9][0-9][0-9]-*' 2>/dev/null | sort)
  return "$failed"
}

config_has_section() {
  local section="$1"
  [[ -f "$CONFIG" ]] && grep -Eq "^${section}:" "$CONFIG"
}

append_config_section_subagents() {
  cat >> "$CONFIG" <<'YAML'

subagents:
  # 模型路由只生成调度建议，不直接调用外部模型。
  # Manager 应根据 feature type、task complexity、risk、role 和用户覆盖项选择中性 reasoning 档位。
  default_model_profile: medium
  model_profiles:
    low:
      codex_reasoning_effort: low
      adapter_hint: "fast responses with lighter reasoning"
      use_for:
        - trivial
        - docs
        - archive
        - low-risk-mechanical-edits
    medium:
      codex_reasoning_effort: medium
      adapter_hint: "balanced speed and reasoning depth"
      use_for:
        - standard
        - bug
        - implementation
        - ai-tests
    high:
      codex_reasoning_effort: high
      adapter_hint: "greater reasoning depth for complex problems"
      use_for:
        - major
        - architecture
        - code-review
        - complex-debugging
    extra-high:
      codex_reasoning_effort: extra-high
      adapter_hint: "maximum reasoning depth for sensitive or critical work"
      use_for:
        - sensitive
        - security-review
        - auth
        - permission
        - payment
  routing_rules:
    trivial: low
    bug: medium
    standard: medium
    major: high
    sensitive: extra-high
YAML
}

append_config_section_testing() {
  cat >> "$CONFIG" <<'YAML'

testing:
  # AI 测试是 feature 级强制闭环：需要生成测试用例，执行可自动化的测试，
  # 并记录结果。人工验收是异步队列，通常到 milestone/release 再集中处理。
  ai_required: true
  require_test_cases: true
  require_test_results: true
  manual_acceptance:
    enabled: true
    blocking_level: release
    allow_pending_before_archive: true
YAML
}

update_feature_bundle_files() {
  local dir="$1"
  local mode="$2"
  local title type missing=0
  title="$(feature_state_value "$dir" "title")"
  title="${title:-$(basename "$dir")}"
  type="$(feature_type_for_dir "$dir")"

  if [[ ! -f "$dir/test-cases.md" ]]; then
    missing=1
    printf 'Missing feature file: %s\n' "$dir/test-cases.md"
    [[ "$mode" == "apply" ]] && render_feature_template "$TEMPLATE_DIR/feature/test-cases.md" "$dir/test-cases.md" "$title" "$title" "$type"
  fi
  if [[ ! -f "$dir/test-results.md" ]]; then
    missing=1
    printf 'Missing feature file: %s\n' "$dir/test-results.md"
    [[ "$mode" == "apply" ]] && render_feature_template "$TEMPLATE_DIR/feature/test-results.md" "$dir/test-results.md" "$title" "$title" "$type"
  fi
  if [[ ! -f "$dir/manual-acceptance.md" ]]; then
    missing=1
    printf 'Missing feature file: %s\n' "$dir/manual-acceptance.md"
    [[ "$mode" == "apply" ]] && render_feature_template "$TEMPLATE_DIR/feature/manual-acceptance.md" "$dir/manual-acceptance.md" "$title" "$title" "$type"
  fi
  if [[ ! -f "$dir/model-routing.md" ]]; then
    missing=1
    printf 'Missing feature file: %s\n' "$dir/model-routing.md"
    [[ "$mode" == "apply" ]] && render_feature_template "$TEMPLATE_DIR/feature/model-routing.md" "$dir/model-routing.md" "$title" "$title" "$type"
  fi

  return "$missing"
}

update_project() {
  local mode="$1"
  local missing=0 feature_dir
  load_project_paths
  printf 'AgentFlow update %s\n' "$mode"
  printf 'CLI version: %s\n' "$(package_version)"

  if [[ ! -f "$CONFIG" ]]; then
    missing=1
    printf 'Missing config: %s\n' "$CONFIG"
    if [[ "$mode" == "apply" ]]; then
      cp "$TEMPLATE_DIR/config/standard.yml" "$CONFIG"
      printf 'Created config from standard template: %s\n' "$CONFIG"
    fi
  else
    if ! config_has_section "subagents"; then
      missing=1
      printf 'Missing config section: subagents\n'
      if [[ "$mode" == "apply" ]]; then
        append_config_section_subagents
        printf 'Appended config section: subagents\n'
      fi
    fi
    if ! config_has_section "testing"; then
      missing=1
      printf 'Missing config section: testing\n'
      if [[ "$mode" == "apply" ]]; then
        append_config_section_testing
        printf 'Appended config section: testing\n'
      fi
    fi
  fi

  mkdir -p "$DOCS_DIR"
  if [[ ! -f "$(manual_acceptance_board_path)" ]]; then
    missing=1
    printf 'Missing project file: %s\n' "$(manual_acceptance_board_path)"
    if [[ "$mode" == "apply" ]]; then
      cp "$TEMPLATE_DIR/project-docs/04_MANUAL_ACCEPTANCE.md" "$(manual_acceptance_board_path)"
      printf 'Created project file: %s\n' "$(manual_acceptance_board_path)"
    fi
  fi

  while IFS= read -r feature_dir; do
    [[ -d "$feature_dir" ]] || continue
    if ! update_feature_bundle_files "$feature_dir" "$mode"; then
      missing=1
    fi
  done < <(find "$FEATURE_DIR" -maxdepth 1 -type d -name 'FEATURE-[0-9][0-9][0-9]-*' 2>/dev/null | sort)

  if [[ "$mode" == "apply" ]]; then
    mkdir -p "$PROJECT_ROOT/.agentflow/templates" "$PROJECT_ROOT/.agentflow/agents"
    cp -n "$PACKAGE_ROOT"/agentflow/templates/feature/* "$PROJECT_ROOT/.agentflow/templates/" 2>/dev/null || true
    cp -n "$PACKAGE_ROOT"/agentflow/templates/records/* "$PROJECT_ROOT/.agentflow/templates/" 2>/dev/null || true
    cp -n "$PACKAGE_ROOT"/agentflow/roles/* "$PROJECT_ROOT/.agentflow/agents/" 2>/dev/null || true
    printf 'Refreshed missing local templates and role files without overwriting existing files.\n'
  fi

  if [[ "$missing" -eq 0 ]]; then
    printf 'Project is up to date for AgentFlow %s.\n' "$(package_version)"
  elif [[ "$mode" == "check" ]]; then
    printf 'Update needed. Run: agentflow update --apply\n'
  else
    printf 'Update applied. Review changes before committing.\n'
  fi
}

task_id_from_title() {
  local title="$1"
  printf '%s' "${title/FEATURE-/TASK-}"
}

dispatch_record_path() {
  local task_id="$1"
  printf '%s/records/dispatch/%s_subagent_dispatch.md' "$DOCS_DIR" "$task_id"
}

test_record_path() {
  local task_id="$1"
  printf '%s/records/test/%s_test.md' "$DOCS_DIR" "$task_id"
}

review_record_path() {
  local task_id="$1"
  printf '%s/records/review/%s_review.md' "$DOCS_DIR" "$task_id"
}

done_record_path() {
  local task_id="$1"
  printf '%s/records/done/%s_done.md' "$DOCS_DIR" "$task_id"
}

manual_acceptance_board_path() {
  printf '%s/04_MANUAL_ACCEPTANCE.md' "$DOCS_DIR"
}

architecture_doc_path() {
  printf '%s/01_ARCHITECTURE.md' "$DOCS_DIR"
}

architecture_status_value() {
  local file
  file="$(architecture_doc_path)"
  if [[ ! -f "$file" ]]; then
    return
  fi
  awk '
    /^Status:[[:space:]]*/ {
      line = $0
      sub(/^Status:[[:space:]]*/, "", line)
      print line
      exit
    }
  ' "$file"
}

check_architecture_ready() {
  local file status failed=0 placeholder_file
  load_project_paths
  file="$(architecture_doc_path)"

  if [[ ! -f "$file" ]]; then
    printf 'Missing architecture document: %s\n' "$file" >&2
    return 1
  fi

  status="$(architecture_status_value)"
  status="${status:-unknown}"
  printf 'Architecture status: %s (%s)\n' "$status" "$file"

  if [[ "$status" != "approved" ]]; then
    printf 'Architecture is not approved. Update %s and set Status: approved after human confirmation.\n' "$file"
    failed=1
  fi

  placeholder_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-architecture-placeholders.XXXXXX")"
  if grep -nE 'TBD|{{[A-Z0-9_]+}}' "$file" >"$placeholder_file" 2>/dev/null; then
    printf 'Open architecture placeholders:\n'
    cat "$placeholder_file"
    failed=1
  fi
  rm -f "$placeholder_file"

  if [[ "$failed" -eq 0 ]]; then
    printf 'Architecture check passed.\n'
  fi
  return "$failed"
}

warn_if_architecture_not_ready() {
  local file status
  load_project_paths
  file="$(architecture_doc_path)"
  if [[ ! -f "$file" ]]; then
    printf 'Warning: architecture document is missing: %s\n' "$file" >&2
    printf 'For full project splitting, run architecture analysis before creating feature bundles.\n' >&2
    return
  fi

  status="$(architecture_status_value)"
  status="${status:-unknown}"
  if [[ "$status" != "approved" ]] || grep -qE 'TBD|{{[A-Z0-9_]+}}' "$file" 2>/dev/null; then
    printf 'Warning: project architecture is not confirmed (%s). For full project splitting, complete %s first.\n' "$status" "$file" >&2
  fi
}

append_manual_acceptance_feature() {
  local feature_name="$1"
  local feature_title="$2"
  local board case_id
  board="$(manual_acceptance_board_path)"
  case_id="MA-${feature_name#FEATURE-}"

  [[ -f "$board" ]] || cp "$TEMPLATE_DIR/project-docs/04_MANUAL_ACCEPTANCE.md" "$board"
  if grep -Fq "| $case_id |" "$board"; then
    return
  fi

  printf '| %s | %s | Define human QA scenarios for %s | Manual expectations documented | pending | Awaiting QA case design | n/a |\n' \
    "$case_id" "$feature_name" "$feature_title" >> "$board"
}

ensure_gitignore_line() {
  local file="$1"
  local line="$2"
  touch "$file"
  if ! grep -Fqx "$line" "$file" 2>/dev/null; then
    printf '%s\n' "$line" >> "$file"
  fi
}

ensure_runtime_gitignore() {
  local gitignore_file="$PROJECT_ROOT/.gitignore"
  ensure_gitignore_line "$gitignore_file" ".agentflow/state/*"
  ensure_gitignore_line "$gitignore_file" "!.agentflow/state/features.yml"
  ensure_gitignore_line "$gitignore_file" "project-docs/records/dispatch/"
  ensure_gitignore_line "$gitignore_file" ".DS_Store"
}

ensure_runtime_dirs() {
  load_project_paths
  mkdir -p \
    "$FEATURE_DIR" \
    "$DOCS_DIR/records/dispatch" \
    "$DOCS_DIR/records/done" \
    "$DOCS_DIR/records/review" \
    "$DOCS_DIR/records/test" \
    "$DOCS_DIR/subagent" \
    "$STATE_DIR" \
    "$MODULES_DIR"

  if [[ ! -f "$DOCS_DIR/00_PROJECT_CONTEXT.md" ]]; then
    cp "$TEMPLATE_DIR/project-docs/00_PROJECT_CONTEXT.md" "$DOCS_DIR/00_PROJECT_CONTEXT.md"
  fi

  if [[ ! -f "$DOCS_DIR/01_ARCHITECTURE.md" ]]; then
    cp "$TEMPLATE_DIR/project-docs/01_ARCHITECTURE.md" "$DOCS_DIR/01_ARCHITECTURE.md"
  fi

  if [[ ! -f "$DOCS_DIR/03_TASK_BOARD.md" ]]; then
    cp "$TEMPLATE_DIR/project-docs/03_TASK_BOARD.md" "$DOCS_DIR/03_TASK_BOARD.md"
  fi

  if [[ ! -f "$DOCS_DIR/02_API_SPEC.md" ]]; then
    cp "$TEMPLATE_DIR/project-docs/02_API_SPEC.md" "$DOCS_DIR/02_API_SPEC.md"
  fi

  if [[ ! -f "$DOCS_DIR/ACTIVE_WORK.md" ]]; then
    cp "$TEMPLATE_DIR/project-docs/ACTIVE_WORK.md" "$DOCS_DIR/ACTIVE_WORK.md"
  fi

  if [[ ! -f "$(manual_acceptance_board_path)" ]]; then
    cp "$TEMPLATE_DIR/project-docs/04_MANUAL_ACCEPTANCE.md" "$(manual_acceptance_board_path)"
  fi

  ensure_features_state

  if [[ ! -f "$MODULES_DIR/external_modules.yml" ]]; then
    cp "$TEMPLATE_DIR/modules/external_modules.yml" "$MODULES_DIR/external_modules.yml"
  fi

  if [[ ! -f "$MODULES_DIR/external_module_policy.yml" ]]; then
    cp "$TEMPLATE_DIR/modules/external_module_policy.yml" "$MODULES_DIR/external_module_policy.yml"
  fi
}

init_project() {
  local profile="${1:-standard}"
  ensure_runtime_dirs
  ensure_runtime_gitignore
  mkdir -p \
    "$PROJECT_ROOT/.agentflow/agents" \
    "$PROJECT_ROOT/.agentflow/workflows" \
    "$PROJECT_ROOT/.agentflow/templates" \
    "$PROJECT_ROOT/.agentflow/integrations" \
    "$PROJECT_ROOT/.agentflow/records" \
    "$PROJECT_ROOT/.agentflow/modules" \
    "$STATE_DIR"

  if [[ ! -f "$PROJECT_ROOT/AGENTS.md" ]]; then
    cp "$TEMPLATE_DIR/project/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
  fi

  if [[ ! -f "$CONFIG" || "$INIT_FORCE" == "true" ]]; then
    cp "$TEMPLATE_DIR/config/$profile.yml" "$CONFIG"
  else
    printf 'Skip existing config: %s (use --force to overwrite)\n' "$CONFIG"
  fi
  load_project_paths
  mkdir -p "$STATE_DIR"
  cp -R "$PACKAGE_ROOT/agentflow/roles/." "$PROJECT_ROOT/.agentflow/agents/"
  cp -R "$PACKAGE_ROOT/agentflow/templates/feature/." "$PROJECT_ROOT/.agentflow/templates/"
  cp -R "$PACKAGE_ROOT/agentflow/templates/records/." "$PROJECT_ROOT/.agentflow/templates/"

  if [[ "$profile" == "standard" || "$profile" == "full" ]]; then
    mkdir -p "$PROJECT_ROOT/.agentflow/skills"
    cp -R "$PACKAGE_ROOT/agentflow/skills/." "$PROJECT_ROOT/.agentflow/skills/"
  fi

  if [[ "$profile" == "full" ]]; then
    cp "$TEMPLATE_DIR/integrations/oh-my-codex.yml" "$PROJECT_ROOT/.agentflow/integrations/oh-my-codex.yml"
  fi

  printf 'AgentFlow initialized with profile: %s\n' "$profile"
}

create_feature() {
  local request="$1"
  shift || true
  local type
  type="$(default_feature_type)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        if [[ $# -lt 2 ]]; then
          printf 'Missing value for --type\n' >&2
          exit 1
        fi
        type="$2"
        shift 2
        ;;
      --type=*)
        type="${1#--type=}"
        shift
        ;;
      *)
        printf 'Unknown feature create option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done
  if ! valid_feature_type "$type"; then
    printf 'Unknown feature type: %s\n' "$type" >&2
    exit 1
  fi
  local id slug name dir side
  load_project_paths
  warn_if_architecture_not_ready
  acquire_state_lock
  trap 'release_state_lock' RETURN
  id="$(next_feature_id)"
  slug="$(slugify "$request")"
  if [[ -z "$slug" ]]; then
    slug="feature"
  fi
  name="FEATURE-$id-$slug"
  dir="$FEATURE_DIR/$name"

  mkdir -p "$dir/implementation" "$dir/results" "$dir/reviews"

  if workflow_stages_for_type "$type" | grep -Fxq "spec"; then
    render_feature_template "$TEMPLATE_DIR/feature/spec.md" "$dir/spec.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "spec" && [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]]; then
    render_feature_template "$TEMPLATE_DIR/feature/spec-review.md" "$dir/spec-review.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "plan"; then
    render_feature_template "$TEMPLATE_DIR/feature/plan.md" "$dir/plan.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "plan" && [[ "$(config_bool "gates" "require_plan_review" "true")" == "true" ]]; then
    render_feature_template "$TEMPLATE_DIR/feature/plan-review.md" "$dir/plan-review.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "tasks"; then
    render_feature_template "$TEMPLATE_DIR/feature/tasks.md" "$dir/tasks.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "tasks" && [[ "$(config_bool "gates" "require_task_review" "true")" == "true" ]]; then
    render_feature_template "$TEMPLATE_DIR/feature/task-review.md" "$dir/task-review.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "dispatch"; then
    render_feature_template "$TEMPLATE_DIR/feature/dispatch.md" "$dir/dispatch.md" "$request" "$request" "$type"
  fi
  render_feature_template "$TEMPLATE_DIR/feature/archive.md" "$dir/archive.md" "$request" "$request" "$type"
  render_feature_template "$TEMPLATE_DIR/feature/implementation-api.md" "$dir/implementation/api.md" "$request" "$request" "$type"
  render_feature_template "$TEMPLATE_DIR/feature/test-cases.md" "$dir/test-cases.md" "$request" "$request" "$type"
  render_feature_template "$TEMPLATE_DIR/feature/test-results.md" "$dir/test-results.md" "$request" "$request" "$type"
  render_feature_template "$TEMPLATE_DIR/feature/manual-acceptance.md" "$dir/manual-acceptance.md" "$request" "$request" "$type"
  render_feature_template "$TEMPLATE_DIR/feature/model-routing.md" "$dir/model-routing.md" "$request" "$request" "$type"
  while IFS= read -r side; do
    render_feature_template "$TEMPLATE_DIR/feature/implementation-$side.md" "$dir/results/$side.md" "$request" "$request" "$type"
  done < <(implementation_target_sides)
  render_feature_template "$TEMPLATE_DIR/feature/implementation-fix.md" "$dir/results/fix.md" "$request" "$request" "$type"
  if workflow_stages_for_type "$type" | grep -Fxq "test" && [[ "$(config_bool "gates" "require_tests_before_done" "true")" == "true" ]]; then
    render_feature_template "$TEMPLATE_DIR/feature/implementation-test.md" "$dir/implementation/test.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "review" && [[ "$(config_bool "gates" "require_review_before_commit" "true")" == "true" ]]; then
    render_feature_template "$TEMPLATE_DIR/feature/implementation-review.md" "$dir/implementation/review.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "reuse-risk"; then
    render_feature_template "$TEMPLATE_DIR/feature/reuse-analysis.md" "$dir/reuse-analysis.md" "$request" "$request" "$type"
    render_feature_template "$TEMPLATE_DIR/feature/external-module-risk.md" "$dir/external-module-risk.md" "$request" "$request" "$type"
  fi
  if workflow_stages_for_type "$type" | grep -Fxq "security-review"; then
    render_feature_template "$TEMPLATE_DIR/feature/security-review.md" "$dir/security-review.md" "$request" "$request" "$type"
  fi

  append_manual_acceptance_feature "$name" "$request"
  upsert_feature_state "$name" "$request" "draft" "pending" "Manager" "subagent" "no" "Created by agentflow feature create" "$type"
  render_task_board

  printf 'Created %s\n' "$dir"
  release_state_lock
  trap - RETURN
}

feature_path() {
  local feature="$1"
  load_project_paths
  if [[ -d "$feature" ]]; then
    printf '%s' "$feature"
  elif [[ -d "$FEATURE_DIR/$feature" ]]; then
    printf '%s' "$FEATURE_DIR/$feature"
  else
    printf 'Unknown feature: %s\n' "$feature" >&2
    exit 1
  fi
}

review_file_for_stage() {
  local dir="$1"
  local stage="$2"
  case "$stage" in
    spec) printf '%s/spec-review.md' "$dir" ;;
    plan) printf '%s/plan-review.md' "$dir" ;;
    tasks|task) printf '%s/task-review.md' "$dir" ;;
    implementation|implement|review) printf '%s/implementation/review.md' "$dir" ;;
    *)
      printf 'Unsupported approval stage: %s\n' "$stage" >&2
      exit 1
      ;;
  esac
}

approve_feature_stage() {
  local feature="$1"
  local stage="$2"
  local dir review_file tmp_file approved_at
  dir="$(feature_path "$feature")"
  review_file="$(review_file_for_stage "$dir" "$stage")"
  if [[ ! -f "$review_file" ]]; then
    printf 'Cannot approve missing review file: %s\n' "$review_file" >&2
    exit 1
  fi

  tmp_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-approval.XXXXXX")"
  grep -Ev '^(approved_by|approved_at|approval_source):' "$review_file" > "$tmp_file" || true
  approved_at="$(date +%Y-%m-%dT%H:%M:%S%z)"
  {
    printf '\n'
    printf 'approved_by: local-user\n'
    printf 'approved_at: %s\n' "$approved_at"
    printf 'approval_source: cli\n'
  } >> "$tmp_file"
  mv "$tmp_file" "$review_file"
  printf 'Approved %s at stage %s via CLI metadata: %s\n' "$(basename "$dir")" "$stage" "$review_file"
}

check_feature() {
  local dir path missing=0 placeholders=0 placeholder_file
  dir="$(feature_path "$1")"

  while IFS= read -r path; do
    if [[ ! -f "$dir/$path" ]]; then
      printf 'Missing: %s\n' "$dir/$path"
      missing=1
    fi
  done < <(required_feature_files_for_dir "$dir")

  placeholder_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-tbd.XXXXXX")"
  if grep -R -nE 'TBD|{{[A-Z0-9_]+}}' "$dir" >"$placeholder_file" 2>/dev/null; then
    printf 'Open placeholders:\n'
    cat "$placeholder_file"
    placeholders=1
  fi
  rm -f "$placeholder_file"

  if [[ "$missing" -eq 0 && "$placeholders" -eq 0 ]]; then
    printf 'Feature bundle structure is complete: %s\n' "$dir"
  else
    return 1
  fi
}

check_feature_health() {
  local dir="$1"
  local id type first_stage path failed=0
  id="$(basename "$dir")"
  type="$(feature_type_for_dir "$dir")"

  if [[ ! -f "$dir/state.yml" ]]; then
    printf 'Missing feature state: %s/state.yml\n' "$dir" >&2
    return 1
  fi

  for path in id title type stage status; do
    if [[ -z "$(feature_state_value "$dir" "$path")" ]]; then
      printf 'Feature state missing %s: %s/state.yml\n' "$path" "$dir" >&2
      failed=1
    fi
  done

  if ! valid_feature_type "$type"; then
    printf 'Invalid feature type for %s: %s\n' "$id" "$type" >&2
    failed=1
  fi

  first_stage="$(workflow_stages_for_type "$type" | head -1)"
  case "$first_stage" in
    spec)
      [[ -f "$dir/spec.md" ]] || { printf 'Missing entry file for %s: %s/spec.md\n' "$id" "$dir" >&2; failed=1; }
      ;;
    implement)
      [[ -f "$dir/implementation/api.md" ]] || { printf 'Missing entry file for %s: %s/implementation/api.md\n' "$id" "$dir" >&2; failed=1; }
      ;;
    *)
      printf 'Unsupported first workflow stage for %s: %s\n' "$id" "$first_stage" >&2
      failed=1
      ;;
  esac

  if [[ "$failed" -eq 0 ]]; then
    printf 'Feature health check passed: %s (%s)\n' "$id" "$type"
  fi
  return "$failed"
}

add_verify_error() {
  VERIFY_ERRORS+=("$1")
}

add_verify_warning() {
  VERIFY_WARNINGS+=("$1")
}

require_file() {
  local file="$1"
  local label="$2"
  if [[ ! -f "$file" ]]; then
    add_verify_error "$label is missing: $file"
    return 1
  fi
  return 0
}

require_no_placeholders() {
  local file="$1"
  local label="$2"
  local matches
  matches="$(grep -nE 'TBD|{{[A-Z0-9_]+}}' "$file" || true)"
  if [[ -n "$matches" ]]; then
    add_verify_error "$label still contains placeholders:
$matches"
  fi
}

require_no_open_checkboxes() {
  local file="$1"
  local label="$2"
  local matches
  matches="$(grep -nE '^- \[ \]' "$file" || true)"
  if [[ -n "$matches" ]]; then
    add_verify_error "$label still has unchecked gate items:
$matches"
  fi
}

require_status_not_pending() {
  local file="$1"
  local label="$2"
  if grep -Eq '^Status:[[:space:]]*pending' "$file"; then
    add_verify_error "$label status is still pending: $file"
  fi
}

verify_structured_record() {
  local file="$1"
  local label="$2"
  require_file "$file" "$label" || return
  require_no_placeholders "$file" "$label"
  require_status_not_pending "$file" "$label"
  require_no_open_checkboxes "$file" "$label"
}

require_line_match() {
  local file="$1"
  local pattern="$2"
  local message="$3"
  if [[ ! -f "$file" ]]; then
    return
  fi
  if ! grep -Eq "$pattern" "$file"; then
    add_verify_error "$message: $file"
  fi
}

require_heading_with_content() {
  local file="$1"
  local heading="$2"
  local message="$3"
  if [[ ! -f "$file" ]]; then
    return
  fi
  awk -v heading="$heading" '
    $0 == heading {
      in_section = 1
      next
    }
    in_section && $0 ~ /^## / {
      exit
    }
    in_section && $0 !~ /^[[:space:]]*$/ {
      found = 1
    }
    END {
      exit found ? 0 : 1
    }
  ' "$file" || add_verify_error "$message: $file"
}

require_review_decision() {
  local file="$1"
  local label="$2"
  if [[ ! -f "$file" ]]; then
    return
  fi
  if ! grep -Eiq '^Status:[[:space:]]*(approved|rejected|needs changes|complete|passed)' "$file"; then
    add_verify_error "$label must have a final decision: approved, rejected, or needs changes: $file"
  fi
}

require_no_blocking_issues() {
  local file="$1"
  local label="$2"
  if [[ ! -f "$file" ]]; then
    return
  fi
  if grep -Eiq 'blocker|must fix|rejected|needs changes' "$file"; then
    add_verify_error "$label still records blocking issues: $file"
  fi
}

metadata_value() {
  local file="$1"
  local key="$2"
  if [[ ! -f "$file" ]]; then
    return
  fi
  awk -v key="$key" '
    $0 ~ "^" key ":" {
      line = $0
      sub("^[^:]+:[[:space:]]*", "", line)
      gsub(/^"/, "", line)
      gsub(/"$/, "", line)
      print line
      exit
    }
  ' "$file"
}

require_review_isolation() {
  local file="$1"
  local label="$2"
  local stage="$3"
  local mode review_mode reviewer decision blocking_issues reviewed_at
  local approved_by approved_at approval_source
  [[ ! -f "$file" ]] && return

  mode="$(review_mode_for_stage "$stage")"
  case "$mode" in
    self)
      add_verify_warning "$label uses review.mode=self; this is a weak review isolation mode."
      ;;
    separate-session)
      review_mode="$(metadata_value "$file" "review_mode")"
      reviewer="$(metadata_value "$file" "reviewer")"
      decision="$(metadata_value "$file" "decision")"
      blocking_issues="$(metadata_value "$file" "blocking_issues")"
      reviewed_at="$(metadata_value "$file" "reviewed_at")"
      [[ "$review_mode" == "separate-session" ]] || add_verify_error "$label missing review_mode: separate-session metadata: $file"
      [[ "$reviewer" == "external" ]] || add_verify_error "$label separate-session review must use reviewer: external: $file"
      [[ "$decision" =~ ^(approved|rejected|needs[[:space:]]changes)$ ]] || add_verify_error "$label separate-session review must declare decision: approved, rejected, or needs changes: $file"
      [[ "$blocking_issues" == "0" ]] || add_verify_error "$label separate-session review must declare blocking_issues: 0: $file"
      [[ -n "$reviewed_at" ]] || add_verify_error "$label separate-session review must include reviewed_at: $file"
      ;;
    human)
      approved_by="$(metadata_value "$file" "approved_by")"
      approved_at="$(metadata_value "$file" "approved_at")"
      approval_source="$(metadata_value "$file" "approval_source")"
      [[ "$approved_by" == "local-user" ]] || add_verify_error "$label requires human approval metadata approved_by: local-user: $file"
      [[ -n "$approved_at" ]] || add_verify_error "$label requires human approval metadata approved_at: $file"
      [[ "$approval_source" == "cli" ]] || add_verify_error "$label requires human approval metadata approval_source: cli: $file"
      ;;
  esac
}

verify_review_gate() {
  local file="$1"
  local label="$2"
  local stage="${3:-}"
  require_file "$file" "$label" || return
  require_no_placeholders "$file" "$label"
  require_status_not_pending "$file" "$label"
  require_no_open_checkboxes "$file" "$label"
  require_review_decision "$file" "$label"
  require_no_blocking_issues "$file" "$label"
  if [[ -n "$stage" ]]; then
    require_review_isolation "$file" "$label" "$stage"
  fi
}

verify_stage_spec() {
  local dir="$1"
  local spec_review_required
  spec_review_required="$(config_bool "gates" "require_spec_review" "true")"

  require_file "$dir/spec.md" "spec.md" || return
  require_no_placeholders "$dir/spec.md" "spec.md"
  require_heading_with_content "$dir/spec.md" "## User Goal" "spec.md is missing an explicit user goal"
  require_heading_with_content "$dir/spec.md" "## Scope" "spec.md is missing explicit scope"
  require_heading_with_content "$dir/spec.md" "## Acceptance Criteria" "spec.md is missing acceptance criteria"

  if [[ "$spec_review_required" == "true" ]]; then
    verify_review_gate "$dir/spec-review.md" "spec-review.md" "spec"
  fi
}

verify_stage_plan() {
  local dir="$1"
  local plan_review_required
  plan_review_required="$(config_bool "gates" "require_plan_review" "true")"

  verify_stage_spec "$dir"
  require_file "$dir/plan.md" "plan.md" || return
  require_no_placeholders "$dir/plan.md" "plan.md"
  require_heading_with_content "$dir/plan.md" "## Architecture" "plan.md is missing implementation approach"
  require_heading_with_content "$dir/plan.md" "## Changed Files" "plan.md is missing impact file list"
  require_heading_with_content "$dir/plan.md" "## Risks" "plan.md is missing risk analysis"

  if [[ "$plan_review_required" == "true" ]]; then
    verify_review_gate "$dir/plan-review.md" "plan-review.md" "plan"
  fi
}

verify_stage_tasks() {
  local dir="$1"
  local task_review_required
  task_review_required="$(config_bool "gates" "require_task_review" "true")"

  verify_stage_plan "$dir"
  require_file "$dir/tasks.md" "tasks.md" || return
  require_no_placeholders "$dir/tasks.md" "tasks.md"
  require_line_match "$dir/tasks.md" '^- \[[ x]\] T[0-9]{3}.+' "tasks.md does not contain executable delivery tasks"
  require_line_match "$dir/tasks.md" 'T[0-9]{3}.*(Backend|Frontend|Mobile|API|Test|Review|Fix|Commit|Archive|Manager|Implementer|Agent|Designer)' "tasks.md tasks must include an owner or execution role"

  if [[ "$task_review_required" == "true" ]]; then
    verify_review_gate "$dir/task-review.md" "task-review.md" "tasks"
  fi
}

verify_stage_dispatch() {
  local dir="$1"
  verify_stage_tasks "$dir"
  require_file "$dir/dispatch.md" "dispatch.md" || return
  require_no_placeholders "$dir/dispatch.md" "dispatch.md"
  require_line_match "$dir/dispatch.md" '^\| Task \| Role \| Model Profile \| Inputs \| Outputs \| Status \|' "dispatch.md is missing role assignment table"
  require_line_match "$dir/dispatch.md" '^\| API design \|' "dispatch.md is missing default dispatch rows"
  verify_structured_record "$dir/model-routing.md" "model-routing.md"
}

verify_stage_implement() {
  local dir="$1"
  local side target_sides
  if feature_has_stage "$dir" "dispatch"; then
    verify_stage_dispatch "$dir"
  elif feature_has_stage "$dir" "tasks"; then
    verify_stage_tasks "$dir"
  elif feature_has_stage "$dir" "plan"; then
    verify_stage_plan "$dir"
  elif feature_has_stage "$dir" "spec"; then
    verify_stage_spec "$dir"
  fi

  verify_structured_record "$dir/implementation/api.md" "implementation/api.md"

  target_sides="$(implementation_target_sides)"
  if [[ -z "$target_sides" ]]; then
    add_verify_error "implementation.target_sides must include at least one of: backend, frontend, mobile"
    return
  fi

  while IFS= read -r side; do
    verify_structured_record "$dir/results/$side.md" "results/$side.md"
  done <<< "$target_sides"
}

verify_stage_reuse_risk() {
  local dir="$1"
  verify_stage_spec "$dir"
  verify_structured_record "$dir/reuse-analysis.md" "reuse-analysis.md"
  verify_structured_record "$dir/external-module-risk.md" "external-module-risk.md"
  require_line_match "$dir/external-module-risk.md" '^human_approval_required:[[:space:]]*true' "external-module-risk.md must require human approval for sensitive reuse"
  if ! reuse_gate_check "$(basename "$dir")" >/dev/null 2>&1; then
    add_verify_error "reuse gate must pass before continuing: $dir"
  fi
}

effective_key_files() {
  local dir="$1"
  local feature_name="$2"
  local task_id side

  printf '%s\n' \
    "$dir/spec.md" \
    "$dir/plan.md" \
    "$dir/tasks.md" \
    "$dir/dispatch.md" \
    "$dir/implementation/api.md"

  if [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]]; then
    printf '%s\n' "$dir/spec-review.md"
  fi
  if [[ "$(config_bool "gates" "require_plan_review" "true")" == "true" ]]; then
    printf '%s\n' "$dir/plan-review.md"
  fi
  if [[ "$(config_bool "gates" "require_task_review" "true")" == "true" ]]; then
    printf '%s\n' "$dir/task-review.md"
  fi

  while IFS= read -r side; do
    printf '%s\n' "$dir/results/$side.md"
  done < <(implementation_target_sides)

  if [[ "$(config_bool "gates" "require_tests_before_done" "true")" == "true" ]]; then
    printf '%s\n' "$dir/test-cases.md"
    printf '%s\n' "$dir/test-results.md"
    printf '%s\n' "$dir/manual-acceptance.md"
    printf '%s\n' "$dir/implementation/test.md"
  fi
  if [[ "$(config_bool "gates" "require_review_before_commit" "true")" == "true" ]]; then
    printf '%s\n' "$dir/implementation/review.md"
  fi

  task_id="$(task_id_from_title "$feature_name")"
  printf '%s\n' \
    "$dir/results/fix.md" \
    "$dir/archive.md" \
    "$(review_record_path "$task_id")" \
    "$(test_record_path "$task_id")" \
    "$(done_record_path "$task_id")"
}

verify_stage_test() {
  local dir="$1"
  local tests_required
  tests_required="$(config_bool "gates" "require_tests_before_done" "true")"
  verify_stage_implement "$dir"

  if [[ "$tests_required" == "true" ]]; then
    verify_structured_record "$dir/test-cases.md" "test-cases.md"
    verify_structured_record "$dir/test-results.md" "test-results.md"
    require_file "$dir/manual-acceptance.md" "manual-acceptance.md"
    require_no_placeholders "$dir/manual-acceptance.md" "manual-acceptance.md"
    require_line_match "$dir/manual-acceptance.md" '^Status:[[:space:]]*(pending|accepted|failed|blocked)' "manual-acceptance.md must declare pending, accepted, failed, or blocked"
    verify_structured_record "$dir/implementation/test.md" "implementation/test.md"
    require_line_match "$dir/implementation/test.md" '^Status:[[:space:]]*(complete|passed)' "implementation/test.md must have a passed or complete result"
    if grep -Eiq 'not tested|untested|not run' "$dir/implementation/test.md"; then
      add_verify_error "implementation/test.md cannot be only not tested: $dir/implementation/test.md"
    fi
  fi
}

verify_stage_security_review() {
  local dir="$1"
  verify_stage_implement "$dir"
  verify_review_gate "$dir/security-review.md" "security-review.md" "implementation"
}

verify_stage_review() {
  local dir="$1"
  local review_required
  review_required="$(config_bool "gates" "require_review_before_commit" "true")"
  if feature_has_stage "$dir" "security-review"; then
    verify_stage_security_review "$dir"
  else
    verify_stage_test "$dir"
  fi

  if [[ "$review_required" == "true" ]]; then
    verify_structured_record "$dir/implementation/review.md" "implementation/review.md"
    require_review_decision "$dir/implementation/review.md" "implementation/review.md"
    require_no_blocking_issues "$dir/implementation/review.md" "implementation/review.md"
    require_review_isolation "$dir/implementation/review.md" "implementation/review.md" "implementation"
  fi
}

verify_stage_fix() {
  local dir="$1"
  if feature_has_stage "$dir" "review"; then
    verify_stage_review "$dir"
  elif feature_has_stage "$dir" "test"; then
    verify_stage_test "$dir"
  else
    verify_stage_implement "$dir"
  fi
  verify_structured_record "$dir/results/fix.md" "results/fix.md"
}

verify_stage_archive() {
  local dir="$1"
  local title task_id dispatch_record dispatch_record_required
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  dispatch_record="$(dispatch_record_path "$task_id")"
  dispatch_record_required="$(config_bool "gates" "require_dispatch_record_for_archive" "true")"
  if feature_has_stage "$dir" "fix"; then
    verify_stage_fix "$dir"
  elif feature_has_stage "$dir" "review"; then
    verify_stage_review "$dir"
  elif feature_has_stage "$dir" "test"; then
    verify_stage_test "$dir"
  else
    verify_stage_implement "$dir"
  fi
  if feature_has_stage "$dir" "dispatch" && [[ "$dispatch_record_required" == "true" ]]; then
    verify_structured_record "$dispatch_record" "dispatch record"
  elif feature_has_stage "$dir" "dispatch" && [[ -f "$dispatch_record" ]]; then
    require_no_placeholders "$dispatch_record" "dispatch record"
  fi
  verify_structured_record "$dir/archive.md" "archive.md"
  require_heading_with_content "$dir/archive.md" "## Summary" "archive.md is missing final result summary"
  require_heading_with_content "$dir/archive.md" "## Changed Files" "archive.md is missing change summary"
  require_heading_with_content "$dir/archive.md" "## Verification" "archive.md is missing test summary"
  require_heading_with_content "$dir/archive.md" "## Remaining Risks" "archive.md is missing remaining issues"
}

verify_stage_done() {
  local dir="$1"
  local title task_id review_record test_record done_record summary_required
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  review_record="$(review_record_path "$task_id")"
  test_record="$(test_record_path "$task_id")"
  done_record="$(done_record_path "$task_id")"
  summary_required="$(config_bool "gates" "require_summary_records_for_done" "true")"

  verify_stage_archive "$dir"

  if [[ "$summary_required" == "true" ]]; then
    verify_structured_record "$review_record" "review record"
    verify_structured_record "$test_record" "test record"
    verify_structured_record "$done_record" "done record"
  fi
}

run_verify_stage_checks() {
  local dir="$1"
  local stage="$2"
  VERIFY_ERRORS=()
  VERIFY_WARNINGS=()
  case "$stage" in
    spec) verify_stage_spec "$dir" ;;
    plan) verify_stage_plan "$dir" ;;
    tasks) verify_stage_tasks "$dir" ;;
    reuse-risk) verify_stage_reuse_risk "$dir" ;;
    dispatch) verify_stage_dispatch "$dir" ;;
    implement) verify_stage_implement "$dir" ;;
    security-review) verify_stage_security_review "$dir" ;;
    test) verify_stage_test "$dir" ;;
    review) verify_stage_review "$dir" ;;
    fix) verify_stage_fix "$dir" ;;
    archive) verify_stage_archive "$dir" ;;
    done) verify_stage_done "$dir" ;;
    *)
      printf 'Unsupported verify stage: %s\n' "$stage" >&2
      exit 1
      ;;
  esac
}

verify_feature() {
  local dir stage
  dir="$(feature_path "$1")"
  stage="$2"
  run_verify_stage_checks "$dir" "$stage"

  if [[ "${#VERIFY_ERRORS[@]}" -eq 0 ]]; then
    printf 'Verify passed for %s at stage %s\n' "$(basename "$dir")" "$stage"
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n'
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning"
      done
    fi
  else
    printf 'Verify failed for %s at stage %s\n' "$(basename "$dir")" "$stage" >&2
    printf '\n' >&2
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n' >&2
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning" >&2
      done
      printf '\n' >&2
    fi
    local error
    for error in "${VERIFY_ERRORS[@]}"; do
      printf -- '- %s\n' "$error" >&2
    done
    exit 1
  fi
}

gate_to_stage() {
  local dir target gate_stage
  dir="$(feature_path "$1")"
  target="$2"
  VERIFY_ERRORS=()

  gate_stage="$(previous_workflow_stage "$dir" "$target")"
  if [[ -z "$gate_stage" ]]; then
    if [[ "$target" == "$(workflow_stages_for_type "$(feature_type_for_dir "$dir")" | head -1)" ]]; then
      printf 'Gate Decision: pass\n'
      printf 'Feature: %s\n' "$(basename "$dir")"
      printf 'Target Stage: %s\n' "$target"
      printf 'Checked Stage: draft\n'
      return
    fi
    printf 'Unsupported gate target for feature type %s: %s\n' "$(feature_type_for_dir "$dir")" "$target" >&2
    exit 1
  fi
  run_verify_stage_checks "$dir" "$gate_stage"

  if [[ "${#VERIFY_ERRORS[@]}" -eq 0 ]]; then
    printf 'Gate Decision: pass\n'
    printf 'Feature: %s\n' "$(basename "$dir")"
    printf 'Target Stage: %s\n' "$target"
    printf 'Checked Stage: %s\n' "$gate_stage"
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n'
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning"
      done
    fi
  else
    printf 'Gate Decision: block\n' >&2
    printf 'Feature: %s\n' "$(basename "$dir")" >&2
    printf 'Target Stage: %s\n' "$target" >&2
    printf 'Checked Stage: %s\n' "$gate_stage" >&2
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n' >&2
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning" >&2
      done
    fi
    printf 'Blockers:\n' >&2
    local error
    for error in "${VERIFY_ERRORS[@]}"; do
      printf -- '- %s\n' "$error" >&2
    done
    exit 1
  fi
}

gate_stage_status() {
  local stage="$1"
  local feature="$2"
  local dir
  dir="$(feature_path "$feature")"
  VERIFY_ERRORS=()

  case "$stage" in
    spec|reuse-risk|plan|tasks|dispatch|implement|security-review|test|review|fix|archive|done)
      if [[ "$stage" != "done" ]] && ! feature_has_stage "$dir" "$stage"; then
        printf 'Gate Decision: skip\n'
        printf 'Feature: %s\n' "$(basename "$dir")"
        printf 'Stage: %s\n' "$stage"
        printf 'Reason: stage is not part of feature type %s\n' "$(feature_type_for_dir "$dir")"
        return
      fi
      run_verify_stage_checks "$dir" "$stage"
      ;;
    *)
      printf 'Unsupported gate stage: %s\n' "$stage" >&2
      exit 1
      ;;
  esac

  if [[ "${#VERIFY_ERRORS[@]}" -eq 0 ]]; then
    printf 'Gate Decision: pass\n'
    printf 'Feature: %s\n' "$(basename "$dir")"
    printf 'Stage: %s\n' "$stage"
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n'
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning"
      done
    fi
  else
    printf 'Gate Decision: block\n' >&2
    printf 'Feature: %s\n' "$(basename "$dir")" >&2
    printf 'Stage: %s\n' "$stage" >&2
    if [[ "${#VERIFY_WARNINGS[@]}" -gt 0 ]]; then
      printf 'Warnings:\n' >&2
      local warning
      for warning in "${VERIFY_WARNINGS[@]}"; do
        printf -- '- %s\n' "$warning" >&2
      done
    fi
    printf 'Blockers:\n' >&2
    local error
    for error in "${VERIFY_ERRORS[@]}"; do
      printf -- '- %s\n' "$error" >&2
    done
    exit 1
  fi
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

infer_feature_stage() {
  local dir="$1"
  local type stages stage reversed=""
  type="$(feature_type_for_dir "$dir")"
  while IFS= read -r stage; do
    reversed="$stage
$reversed"
  done < <(workflow_stages_for_type "$type")

  while IFS= read -r stage; do
    [[ -z "$stage" ]] && continue
    if run_verify_stage_checks "$dir" "$stage" && [[ "${#VERIFY_ERRORS[@]}" -eq 0 ]]; then
      printf '%s' "$stage"
      return
    fi
  done <<< "$reversed"

  printf 'draft'
}

next_gate_for_stage() {
  local stage="$1"
  local dir="${2:-}"
  if [[ -n "$dir" ]]; then
    next_workflow_stage "$dir" "$stage"
  else
    case "$stage" in
      draft|spec) printf 'plan' ;;
      plan) printf 'tasks' ;;
      tasks) printf 'dispatch' ;;
      dispatch) printf 'implement' ;;
      implement) printf 'test' ;;
      test) printf 'review' ;;
      review) printf 'fix' ;;
      fix) printf 'archive' ;;
      archive) printf 'done' ;;
      done) printf 'complete' ;;
      *) printf 'plan' ;;
    esac
  fi
}

stage_progress_percent() {
  local stage="$1"
  case "$stage" in
    draft) printf '0' ;;
    spec) printf '15' ;;
    plan) printf '30' ;;
    tasks) printf '45' ;;
    dispatch) printf '55' ;;
    implement) printf '70' ;;
    test) printf '80' ;;
    review) printf '88' ;;
    fix) printf '94' ;;
    archive) printf '100' ;;
    done) printf '100' ;;
    *) printf '0' ;;
  esac
}

task_should_be_checked() {
  local task_id="$1"
  local stage="$2"
  case "$task_id" in
    T001)
      [[ "$stage" =~ ^(implement|test|review|fix|archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    T002|T003|T004)
      [[ "$stage" =~ ^(implement|test|review|fix|archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    T005)
      [[ "$stage" =~ ^(test|review|fix|archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    T006)
      [[ "$stage" =~ ^(review|fix|archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    T007)
      [[ "$stage" =~ ^(fix|archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    T008|T009)
      [[ "$stage" =~ ^(archive|done)$ ]] && printf 'true' || printf 'false'
      ;;
    *)
      printf 'false'
      ;;
  esac
}

emit_json_array_from_lines() {
  local lines="$1"
  local prefix="$2"
  local first=1
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ "$first" -eq 0 ]]; then
      printf ',\n'
    fi
    printf '%s"%s"' "$prefix" "$(json_escape "$line")"
    first=0
  done <<< "$lines"
}

emit_markdown_list_from_lines() {
  local lines="$1"
  local fallback="$2"
  local printed=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    line="$(printf '%s' "$line" | sed -E 's/^[[:space:]]*[-*][[:space:]]+//')"
    printf -- '- %s\n' "$line"
    printed=1
  done <<< "$lines"
  if [[ "$printed" -eq 0 ]]; then
    printf -- '- %s\n' "$fallback"
  fi
}

markdown_section_content() {
  local file="$1"
  local heading="$2"
  if [[ ! -f "$file" ]]; then
    return
  fi
  awk -v heading="$heading" '
    $0 == heading {
      in_section = 1
      next
    }
    in_section && $0 ~ /^## / {
      exit
    }
    in_section {
      print
    }
  ' "$file" |
    sed -E 's/[[:space:]]+$//' |
    sed '/^[[:space:]]*$/d' |
    head -12
}

first_nonempty_line() {
  local text="$1"
  local fallback="$2"
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    printf '%s' "$line"
    return
  done <<< "$text"
  printf '%s' "$fallback"
}

stage_context_mode() {
  local stage="$1"
  case "$stage" in
    draft|spec|plan|tasks) printf 'planning' ;;
    dispatch) printf 'dispatch' ;;
    implement) printf 'implementation' ;;
    test) printf 'testing' ;;
    security-review|review) printf 'review' ;;
    fix) printf 'fix' ;;
    archive|done) printf 'archive' ;;
    *) printf 'general' ;;
  esac
}

optional_files_for_context() {
  local key_files="$1"
  local must_read="$2"
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if ! printf '%s\n' "$must_read" | grep -Fqx "$file"; then
      printf '%s\n' "$file"
    fi
  done <<< "$key_files"
}

required_files_for_gate() {
  local dir="$1"
  local gate="$2"
  local side
  case "$gate" in
    plan)
      printf '%s\n' "$dir/spec.md"
      [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]] && printf '%s\n' "$dir/spec-review.md"
      ;;
    tasks)
      printf '%s\n' "$dir/spec.md" "$dir/plan.md"
      [[ "$(config_bool "gates" "require_plan_review" "true")" == "true" ]] && printf '%s\n' "$dir/plan-review.md"
      ;;
    dispatch)
      printf '%s\n' "$dir/spec.md" "$dir/plan.md" "$dir/tasks.md"
      [[ "$(config_bool "gates" "require_task_review" "true")" == "true" ]] && printf '%s\n' "$dir/task-review.md"
      ;;
    implement)
      feature_has_stage "$dir" "dispatch" && printf '%s\n' "$dir/dispatch.md"
      printf '%s\n' "$dir/implementation/api.md"
      while IFS= read -r side; do
        printf '%s\n' "$dir/results/$side.md"
      done < <(implementation_target_sides)
      ;;
    reuse-risk)
      printf '%s\n' "$dir/reuse-analysis.md" "$dir/external-module-risk.md"
      ;;
    security-review)
      printf '%s\n' "$dir/security-review.md"
      ;;
    test)
      printf '%s\n' "$dir/test-cases.md" "$dir/test-results.md" "$dir/manual-acceptance.md" "$dir/implementation/test.md"
      ;;
    review)
      printf '%s\n' "$dir/implementation/review.md"
      ;;
    fix)
      printf '%s\n' "$dir/results/fix.md"
      ;;
    archive)
      printf '%s\n' "$dir/archive.md"
      ;;
    done)
      printf '%s\n' \
        "$(review_record_path "$(task_id_from_title "$(basename "$dir")")")" \
        "$(test_record_path "$(task_id_from_title "$(basename "$dir")")")" \
        "$(done_record_path "$(task_id_from_title "$(basename "$dir")")")"
      ;;
    complete)
      printf 'No required files; feature is complete.\n'
      ;;
    *)
      effective_key_files "$dir" "$(basename "$dir")"
      ;;
  esac
}

must_read_files_for_stage() {
  local dir="$1"
  local stage="$2"
  case "$stage" in
    draft|spec)
      printf '%s\n' "$dir/spec.md"
      [[ "$(config_bool "gates" "require_spec_review" "true")" == "true" ]] && printf '%s\n' "$dir/spec-review.md"
      ;;
    plan)
      printf '%s\n' "$dir/spec.md" "$dir/plan.md"
      ;;
    tasks)
      printf '%s\n' "$dir/spec.md" "$dir/plan.md" "$dir/tasks.md"
      ;;
    dispatch|implement)
      feature_has_stage "$dir" "plan" && printf '%s\n' "$dir/plan.md"
      feature_has_stage "$dir" "tasks" && printf '%s\n' "$dir/tasks.md"
      feature_has_stage "$dir" "dispatch" && printf '%s\n' "$dir/dispatch.md"
      printf '%s\n' "$dir/implementation/api.md"
      ;;
    reuse-risk)
      printf '%s\n' "$dir/spec.md" "$dir/reuse-analysis.md" "$dir/external-module-risk.md"
      ;;
    security-review)
      printf '%s\n' "$dir/security-review.md" "$dir/implementation/api.md"
      ;;
    test)
      printf '%s\n' "$dir/tasks.md" "$dir/test-cases.md" "$dir/test-results.md" "$dir/manual-acceptance.md" "$dir/implementation/test.md"
      ;;
    review|fix)
      printf '%s\n' "$dir/implementation/review.md" "$dir/results/fix.md"
      ;;
    archive|done)
      printf '%s\n' "$dir/archive.md"
      ;;
    *)
      printf '%s\n' "$dir/spec.md" "$dir/plan.md" "$dir/tasks.md"
      ;;
  esac
}

next_step_for_context() {
  local next_gate="$1"
  local feature_name="$2"
  case "$next_gate" in
    complete) printf 'No next gate; feature is complete.' ;;
    *) printf 'Run `agentflow gate %s %s` and resolve the first blocker before advancing.' "$next_gate" "$feature_name" ;;
  esac
}

forbidden_actions_for_context() {
  cat <<'TEXT'
Do not start coding before checking the current gate.
Do not edit generated runtime state by hand.
Do not skip required review, test, or archive records.
Do not open unrelated docs or code unless the current task requires verification.
TEXT
}

build_active_context() {
  local dir="$1"
  local feature_name feature_type workflow_stages current_stage next_gate output_file md_output_file
  local open_tasks key_files required_files must_read related_files goal open_questions blockers next_step forbidden_actions
  local context_mode optional_files
  local error blocker_count
  feature_name="$(basename "$dir")"
  feature_type="$(feature_type_for_dir "$dir")"
  workflow_stages="$(workflow_stages_for_type "$feature_type")"
  current_stage="$(infer_feature_stage "$dir")"
  context_mode="$(stage_context_mode "$current_stage")"
  next_gate="$(next_gate_for_stage "$current_stage" "$dir")"
  ensure_runtime_dirs
  output_file="$STATE_DIR/$ACTIVE_CONTEXT_FILE"
  md_output_file="$STATE_DIR/$ACTIVE_CONTEXT_MD_FILE"

  open_tasks="$(grep -E '^- \[ \] T[0-9]{3}' "$dir/tasks.md" 2>/dev/null || true)"
  key_files="$(effective_key_files "$dir" "$feature_name")"
  required_files="$(required_files_for_gate "$dir" "$next_gate")"
  must_read="$(must_read_files_for_stage "$dir" "$current_stage")"
  optional_files="$(optional_files_for_context "$key_files" "$must_read")"
  related_files="$(printf '%s\n%s\n' "$must_read" "$required_files" | sed '/^$/d' | awk '!seen[$0]++' | head -12)"
  goal="$(first_nonempty_line "$(markdown_section_content "$dir/spec.md" "## User Goal")" "Goal not captured yet.")"
  open_questions="$(markdown_section_content "$dir/spec.md" "## Open Questions")"
  next_step="$(next_step_for_context "$next_gate" "$feature_name")"
  forbidden_actions="$(forbidden_actions_for_context)"
  VERIFY_ERRORS=()
  if [[ "$next_gate" != "complete" ]]; then
    blockers=""
    blocker_count=0
    local blocker_stage
    blocker_stage="$(previous_workflow_stage "$dir" "$next_gate")"
    if [[ -n "$blocker_stage" ]]; then
      run_verify_stage_checks "$dir" "$blocker_stage"
      for error in "${VERIFY_ERRORS[@]}"; do
        blockers="${blockers}$(first_nonempty_line "$error" "$error")
"
        blocker_count=$((blocker_count + 1))
        [[ "$blocker_count" -ge 5 ]] && break
      done
    fi
  else
    blockers=""
  fi

  cat > "$output_file" <<JSON
{
  "feature": "$(json_escape "$feature_name")",
  "feature_dir": "$(json_escape "$dir")",
  "feature_type": "$(json_escape "$feature_type")",
  "current_stage": "$(json_escape "$current_stage")",
  "context_mode": "$(json_escape "$context_mode")",
  "next_gate": "$(json_escape "$next_gate")",
  "goal": "$(json_escape "$goal")",
  "next_step": "$(json_escape "$next_step")",
  "open_tasks": [
$(emit_json_array_from_lines "$open_tasks" "    ")
  ],
  "required_files": [
$(emit_json_array_from_lines "$required_files" "    ")
  ],
  "must_read": [
$(emit_json_array_from_lines "$must_read" "    ")
  ],
  "optional_files": [
$(emit_json_array_from_lines "$optional_files" "    ")
  ],
  "workflow_stages": [
$(emit_json_array_from_lines "$workflow_stages" "    ")
  ],
  "forbidden_actions": [
$(emit_json_array_from_lines "$forbidden_actions" "    ")
  ],
  "open_questions": [
$(emit_json_array_from_lines "$open_questions" "    ")
  ],
  "current_blockers": [
$(emit_json_array_from_lines "$blockers" "    ")
  ],
  "key_files": [
$(emit_json_array_from_lines "$key_files" "    ")
  ]
}
JSON

  cat > "$md_output_file" <<MD
# Active Context

This is the current working contract.
Start from this file before doing any work.
Do not start coding before checking the current gate.
Only open additional docs/files when this context references them or the current task requires verification.

## Feature

$feature_name

## Feature Type

$feature_type

## Workflow Stages

$(emit_markdown_list_from_lines "$workflow_stages" "No workflow stages inferred.")

## Current Stage

$current_stage

## Context Mode

$context_mode

## Current Gate

$next_gate

## Goal

$goal

## Required Files

$(emit_markdown_list_from_lines "$required_files" "No required files for the current gate.")

## Must Read

$(emit_markdown_list_from_lines "$must_read" "No must-read files inferred.")

## Optional Only If Needed

$(emit_markdown_list_from_lines "$optional_files" "No optional files listed.")

## Forbidden Actions

$(emit_markdown_list_from_lines "$forbidden_actions" "No additional forbidden actions.")

## Next Step

$next_step

## Current Blockers

$(emit_markdown_list_from_lines "$blockers" "No current gate blockers detected.")

## Open Questions

$(emit_markdown_list_from_lines "$open_questions" "No open questions captured.")

## Related Code Files

$(emit_markdown_list_from_lines "$related_files" "No related files inferred.")
MD

  printf 'Wrote active context: %s\n' "$output_file"
  printf 'Wrote active context: %s\n' "$md_output_file"
}

record_status_label() {
  local path="$1"
  if [[ -f "$path" ]]; then
    printf 'present'
  else
    printf 'missing'
  fi
}

stage_for_next_gate_check() {
  local gate_target="$1"
  case "$gate_target" in
    plan) printf 'spec' ;;
    tasks) printf 'plan' ;;
    dispatch) printf 'tasks' ;;
    implement) printf 'dispatch' ;;
    test) printf 'implement' ;;
    review) printf 'test' ;;
    fix) printf 'review' ;;
    archive) printf 'fix' ;;
    done) printf 'archive' ;;
    complete) printf 'done' ;;
    *) printf '' ;;
  esac
}

print_status() {
  local dir title task_id current_stage next_gate check_stage
  local state_title state_type state_mode state_owner state_verified state_notes status_label
  local dispatch_record review_record test_record done_record
  local open_tasks open_task_count total_task_count checked_task_count progress_percent
  local effective_open_tasks checklist_note
  dir="$(feature_path "$1")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  current_stage="$(infer_feature_stage "$dir")"
  next_gate="$(next_gate_for_stage "$current_stage" "$dir")"
  check_stage="$(previous_workflow_stage "$dir" "$next_gate")"
  dispatch_record="$(dispatch_record_path "$task_id")"
  review_record="$(review_record_path "$task_id")"
  test_record="$(test_record_path "$task_id")"
  done_record="$(done_record_path "$task_id")"
  open_tasks="$(grep -E '^- \[ \] T[0-9]{3}' "$dir/tasks.md" 2>/dev/null || true)"
  open_task_count="$(printf '%s\n' "$open_tasks" | sed '/^$/d' | wc -l | tr -d ' ')"
  total_task_count="$(grep -Ec '^- \[[ x]\] T[0-9]{3}' "$dir/tasks.md" 2>/dev/null || true)"
  checked_task_count="$(grep -Ec '^- \[x\] T[0-9]{3}' "$dir/tasks.md" 2>/dev/null || true)"
  progress_percent="$(stage_progress_percent "$current_stage")"
  effective_open_tasks="${open_task_count:-0}"
  checklist_note=""
  state_title="$(feature_state_value "$dir" "title")"
  state_type="$(feature_type_for_dir "$dir")"
  state_mode="$(feature_state_value "$dir" "mode")"
  state_owner="$(feature_state_value "$dir" "owner")"
  state_verified="$(feature_state_value "$dir" "verified")"
  state_notes="$(feature_state_value "$dir" "notes")"

  if [[ "$current_stage" =~ ^(archive|done)$ ]]; then
    effective_open_tasks="0"
    if [[ "${open_task_count:-0}" != "0" ]]; then
      checklist_note="task checklist appears stale relative to runtime stage"
    fi
  elif [[ "$current_stage" =~ ^(implement|test|review|fix)$ ]] && [[ "${open_task_count:-0}" != "0" ]]; then
    checklist_note="task checklist may lag behind runtime progress"
  fi

  printf 'Feature: %s\n' "$title"
  printf 'Current Stage: %s\n' "$current_stage"
  printf 'Next Gate: %s\n' "$next_gate"
  printf 'Progress: %s%%\n' "$progress_percent"
  printf 'Open Tasks: %s\n' "$effective_open_tasks"
  printf 'Task Checklist: %s/%s checked\n' "${checked_task_count:-0}" "${total_task_count:-0}"
  if [[ -n "$checklist_note" ]]; then
    printf 'Checklist Note: %s\n' "$checklist_note"
  fi
  printf '\n'
  printf 'Records:\n'
  printf '  dispatch: %s\n' "$(record_status_label "$dispatch_record")"
  printf '  test: %s\n' "$(record_status_label "$test_record")"
  printf '  review: %s\n' "$(record_status_label "$review_record")"
  printf '  done: %s\n' "$(record_status_label "$done_record")"
  printf '\n'

  if [[ "$next_gate" == "complete" ]]; then
    printf 'Gate Status: complete\n'
    status_label="complete"
    upsert_feature_state "$title" "${state_title:-$title}" "$current_stage" "$status_label" "${state_owner:-Manager}" "${state_mode:-subagent}" "${state_verified:-yes}" "${state_notes:-Updated by agentflow feature status}" "$state_type"
    render_task_board >/dev/null
    return
  fi

  if [[ -n "$check_stage" ]]; then
    run_verify_stage_checks "$dir" "$check_stage"
    if [[ "${#VERIFY_ERRORS[@]}" -eq 0 ]]; then
      printf 'Gate Status: ready for %s\n' "$next_gate"
      status_label="ready for $next_gate"
    else
      printf 'Gate Status: blocked before %s\n' "$next_gate"
      status_label="blocked before $next_gate"
      printf 'Top Blockers:\n'
      local blocker limit=0
      for blocker in "${VERIFY_ERRORS[@]}"; do
        printf -- '  - %s\n' "$blocker"
        limit=$((limit + 1))
        if [[ "$limit" -ge 5 ]]; then
          break
        fi
      done
    fi
  elif [[ "$next_gate" == "complete" ]]; then
    status_label="complete"
  else
    status_label="pending"
  fi

  upsert_feature_state "$title" "${state_title:-$title}" "$current_stage" "$status_label" "${state_owner:-Manager}" "${state_mode:-subagent}" "${state_verified:-no}" "${state_notes:-Updated by agentflow feature status}" "$state_type"
  render_task_board >/dev/null
}

advance_feature() {
  local feature="$1"
  local target="$2"
  local dir completed_stage
  dir="$(feature_path "$feature")"

  run_stage_hooks "before" "$target" "$(basename "$dir")" "$dir"
  gate_to_stage "$feature" "$target"
  completed_stage="$(previous_workflow_stage "$dir" "$target")"
  run_stage_hooks "after" "$completed_stage" "$(basename "$dir")" "$dir"
  sync_tasks_for_feature "$feature"
  build_active_context "$dir"
  print_status "$feature"
}

advance_feature_to_next_step() {
  local dir current_stage next_gate feature
  feature="$1"
  dir="$(feature_path "$feature")"
  current_stage="$(infer_feature_stage "$dir")"
  next_gate="$(next_gate_for_stage "$current_stage" "$dir")"

  case "$next_gate" in
    spec|reuse-risk|plan|tasks|dispatch|implement|security-review|test|review|fix|archive)
      if [[ "$next_gate" == "archive" ]]; then
        archive_feature "$feature"
        sync_tasks_for_feature "$feature"
        build_active_context "$dir"
        print_status "$feature"
      else
        advance_feature "$feature" "$next_gate"
      fi
      ;;
    done)
      archive_feature "$feature"
      sync_tasks_for_feature "$feature"
      build_active_context "$dir"
      print_status "$feature"
      ;;
    complete)
      print_status "$feature"
      ;;
    *)
      printf 'Unable to determine next step for %s\n' "$feature" >&2
      exit 1
      ;;
  esac
}

handle_feature_command() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
    create)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      create_feature "$@"
      ;;
    next)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      advance_feature_to_next_step "$1"
      ;;
    verify)
      if [[ $# -lt 3 ]]; then usage; exit 1; fi
      verify_feature "$1" "$(parse_stage_flag "--stage" "${@:2}")"
      ;;
    gate)
      if [[ $# -lt 3 ]]; then usage; exit 1; fi
      gate_to_stage "$1" "$(parse_stage_flag "--to" "${@:2}")"
      ;;
    advance)
      if [[ $# -lt 3 ]]; then usage; exit 1; fi
      advance_feature "$1" "$(parse_stage_flag "--to" "${@:2}")"
      ;;
    context)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      build_active_context "$(feature_path "$1")"
      ;;
    status)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      print_status "$1"
      ;;
    sync)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      sync_tasks_for_feature "$1"
      ;;
    dispatch)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      dispatch_feature "$1"
      ;;
    archive)
      if [[ $# -lt 1 ]]; then usage; exit 1; fi
      archive_feature "$1"
      ;;
    "")
      usage
      exit 1
      ;;
    *)
      # Backward-compatible shorthand: `agentflow feature "title"`
      create_feature "$subcommand"
      ;;
  esac
}

handle_board_command() {
  local subcommand="${1:-}"
  local option="${2:-}"
  case "$subcommand" in
    render)
      if [[ "$option" == "--check" ]]; then
        check_task_board_fresh
      elif [[ -z "$option" ]]; then
        render_task_board
      else
        usage
        exit 1
      fi
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

handle_architecture_command() {
  local subcommand="${1:-}"
  case "$subcommand" in
    check|"")
      check_architecture_ready
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

handle_module_command() {
  local subcommand="${1:-}"
  shift || true
  case "$subcommand" in
    list)
      module_list
      ;;
    show)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      module_show "$1"
      ;;
    add)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      module_add "$@"
      ;;
    contract)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      module_contract "$1"
      ;;
    approve)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      module_approve "$@"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

handle_reuse_command() {
  local subcommand="${1:-}"
  shift || true
  case "$subcommand" in
    analyze)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      reuse_analyze "$1"
      ;;
    gate)
      [[ $# -ge 1 ]] || { usage; exit 1; }
      reuse_gate "$1"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

parse_adapter_flag() {
  local adapter="codex"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --adapter)
        [[ $# -ge 2 ]] || { printf 'Missing value for --adapter\n' >&2; exit 1; }
        adapter="$2"
        shift 2
        ;;
      --adapter=*)
        adapter="${1#--adapter=}"
        shift
        ;;
      --execute)
        shift
        ;;
      --stage)
        [[ $# -ge 2 ]] || { printf 'Missing value for --stage\n' >&2; exit 1; }
        shift 2
        ;;
      --stage=*)
        shift
        ;;
      *)
        printf 'Unknown dispatch option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done
  printf '%s' "$adapter"
}

has_execute_flag() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --execute) return 0 ;;
    esac
    shift
  done
  return 1
}

parse_optional_stage_flag() {
  local value=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stage)
        [[ $# -ge 2 ]] || { printf 'Missing value for --stage\n' >&2; exit 1; }
        value="$2"
        shift 2
        ;;
      --stage=*)
        value="${1#--stage=}"
        shift
        ;;
      --adapter|--adapter=*|--execute)
        if [[ "$1" == "--adapter" ]]; then
          shift 2
        else
          shift
        fi
        ;;
      *)
        printf 'Unknown stage option: %s\n' "$1" >&2
        exit 1
        ;;
    esac
  done
  if [[ -z "$value" ]]; then
    printf 'Missing required --stage option\n' >&2
    exit 1
  fi
  printf '%s' "$value"
}

handle_dispatch_command() {
  local subcmd feature adapter execute="false"
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  subcmd="$1"
  case "$subcmd" in
    plan)
      [[ $# -ge 2 ]] || { usage; exit 1; }
      feature="$2"
      adapter="$(parse_adapter_flag "${@:3}")"
      case "$adapter" in
        codex) dispatch_codex_plan "$feature" ;;
        *) printf 'Unsupported dispatch adapter: %s\n' "$adapter" >&2; exit 1 ;;
      esac
      ;;
    run)
      [[ $# -ge 2 ]] || { usage; exit 1; }
      feature="$2"
      adapter="$(parse_adapter_flag "${@:3}")"
      has_execute_flag "${@:3}" && execute="true"
      case "$adapter" in
        codex) dispatch_codex_run "$feature" "$execute" ;;
        *) printf 'Unsupported dispatch adapter: %s\n' "$adapter" >&2; exit 1 ;;
      esac
      ;;
    *)
      dispatch_feature "$subcmd"
      ;;
  esac
}

handle_stage_command() {
  local subcmd feature stage adapter execute="false"
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  subcmd="$1"
  case "$subcmd" in
    plan)
      [[ $# -ge 2 ]] || { usage; exit 1; }
      feature="$2"
      stage="$(parse_optional_stage_flag "${@:3}")"
      adapter="$(parse_adapter_flag "${@:3}")"
      case "$adapter" in
        codex) stage_codex_plan "$feature" "$stage" ;;
        *) printf 'Unsupported stage adapter: %s\n' "$adapter" >&2; exit 1 ;;
      esac
      ;;
    run)
      [[ $# -ge 2 ]] || { usage; exit 1; }
      feature="$2"
      stage="$(parse_optional_stage_flag "${@:3}")"
      adapter="$(parse_adapter_flag "${@:3}")"
      has_execute_flag "${@:3}" && execute="true"
      case "$adapter" in
        codex) stage_codex_run "$feature" "$stage" "$execute" ;;
        *) printf 'Unsupported stage adapter: %s\n' "$adapter" >&2; exit 1 ;;
      esac
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

sync_tasks_for_feature() {
  local dir tasks_file current_stage tmp_file changes=0
  dir="$(feature_path "$1")"
  tasks_file="$dir/tasks.md"
  current_stage="$(infer_feature_stage "$dir")"

  if [[ ! -f "$tasks_file" ]]; then
    printf 'No tasks file for %s; skipping task checklist sync\n' "$(basename "$dir")"
    return
  fi

  tmp_file="$(mktemp "${TMPDIR:-/tmp}/agentflow-tasks-sync.XXXXXX")"
  awk -v stage="$current_stage" '
    function should_check(task_id, stage_name) {
      if (task_id == "T001") return stage_name ~ /^(implement|test|review|fix|archive|done)$/
      if (task_id == "T002" || task_id == "T003" || task_id == "T004") return stage_name ~ /^(implement|test|review|fix|archive|done)$/
      if (task_id == "T005") return stage_name ~ /^(test|review|fix|archive|done)$/
      if (task_id == "T006") return stage_name ~ /^(review|fix|archive|done)$/
      if (task_id == "T007") return stage_name ~ /^(fix|archive|done)$/
      if (task_id == "T008" || task_id == "T009") return stage_name ~ /^(archive|done)$/
      return 0
    }
    {
      if ($0 ~ /^- \[[ x]\] T00[1-9] /) {
        task_id = substr($0, 7, 4)
        desired = should_check(task_id, stage) ? "x" : " "
        sub(/^- \[[ x]\]/, "- [" desired "]", $0)
      }
      print
    }
  ' "$tasks_file" > "$tmp_file"

  if ! cmp -s "$tasks_file" "$tmp_file"; then
    mv "$tmp_file" "$tasks_file"
    changes=1
  else
    rm -f "$tmp_file"
  fi

  if [[ "$changes" -eq 1 ]]; then
    printf 'Synced standard task checklist for %s at stage %s\n' "$(basename "$dir")" "$current_stage"
  else
    printf 'Task checklist already aligned for %s at stage %s\n' "$(basename "$dir")" "$current_stage"
  fi
}

dispatch_feature() {
  local dir title task_id record enforce_dispatch_gate completed_stage
  dir="$(feature_path "$1")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  enforce_dispatch_gate="$(config_bool "runtime" "enforce_dispatch_gate" "true")"

  if [[ "$enforce_dispatch_gate" == "true" ]]; then
    run_stage_hooks "before" "dispatch" "$title" "$dir"
    gate_to_stage "$title" "dispatch"
    completed_stage="$(completed_stage_for_gate_target "dispatch")"
    run_stage_hooks "after" "$completed_stage" "$title" "$dir"
  fi

  ensure_runtime_dirs
  record="$(dispatch_record_path "$task_id")"

  render_vars "$TEMPLATE_DIR/records/dispatch-record.md" "$record" "$task_id" "Implementation Team" "Implement $title from Feature Bundle" "$dir"

  printf 'Created subagent dispatch record: %s\n' "$record"
  printf 'Use subagents from %s.\n' "$dir/dispatch.md"
}

archive_feature() {
  local dir title task_id enforce_archive_gate completed_stage
  local review_record test_record done_record
  dir="$(feature_path "$1")"
  title="$(basename "$dir")"
  task_id="$(task_id_from_title "$title")"
  enforce_archive_gate="$(config_bool "runtime" "enforce_archive_gate" "true")"

  if [[ "$enforce_archive_gate" == "true" ]]; then
    run_stage_hooks "before" "archive" "$title" "$dir"
    gate_to_stage "$title" "archive"
    completed_stage="$(completed_stage_for_gate_target "archive")"
    run_stage_hooks "after" "$completed_stage" "$title" "$dir"
  fi

  ensure_runtime_dirs
  review_record="$(review_record_path "$task_id")"
  test_record="$(test_record_path "$task_id")"
  done_record="$(done_record_path "$task_id")"

  render_vars "$TEMPLATE_DIR/records/review-record.md" "$review_record" "$task_id" "Code Reviewer" "Summarize review outcome for $title" "$dir"
  render_vars "$TEMPLATE_DIR/records/test-record.md" "$test_record" "$task_id" "Test Agent" "Summarize test outcome for $title" "$dir"
  render_vars "$TEMPLATE_DIR/records/done-record.md" "$done_record" "$task_id" "Commit Agent" "Finalize archive and delivery summary for $title" "$dir"

  upsert_feature_state "$title" "$(feature_state_value "$dir" "title" || printf '%s' "$title")" "archive" "pending" "Manager" "subagent" "no" "See $dir/archive.md" "$(feature_type_for_dir "$dir")"
  render_task_board

  printf 'Wrote summary records:\n'
  printf '  %s\n' "$review_record"
  printf '  %s\n' "$test_record"
  printf '  %s\n' "$done_record"
  printf 'Archive linked in task board: %s\n' "$DOCS_DIR/03_TASK_BOARD.md"
}

doctor_check() {
  local failed=0 feature_dir state_file required_template git_root missing_feature_state=0
  load_project_paths
  printf 'AgentFlow doctor\n'

  for required_template in bash awk sed find grep; do
    if command -v "$required_template" >/dev/null 2>&1; then
      printf 'OK command: %s\n' "$required_template"
    else
      printf 'FAIL missing command: %s\n' "$required_template" >&2
      failed=1
    fi
  done

  [[ -f "$CONFIG" ]] && printf 'OK config: %s\n' "$CONFIG" || { printf 'FAIL missing config: %s\n' "$CONFIG" >&2; failed=1; }

  for required_template in \
    "$TEMPLATE_DIR/project/AGENTS.md" \
    "$TEMPLATE_DIR/project-docs/03_TASK_BOARD.md" \
    "$TEMPLATE_DIR/project-docs/04_MANUAL_ACCEPTANCE.md" \
    "$TEMPLATE_DIR/adapters/codex-dispatch-prompt.md" \
    "$TEMPLATE_DIR/feature/archive.md" \
    "$TEMPLATE_DIR/feature/implementation-api.md" \
    "$TEMPLATE_DIR/feature/model-routing.md" \
    "$TEMPLATE_DIR/feature/test-cases.md" \
    "$TEMPLATE_DIR/feature/test-results.md" \
    "$TEMPLATE_DIR/feature/manual-acceptance.md" \
    "$TEMPLATE_DIR/modules/external_modules.yml" \
    "$TEMPLATE_DIR/modules/external_module_policy.yml"; do
    [[ -f "$required_template" ]] && printf 'OK template: %s\n' "$required_template" || { printf 'FAIL missing template: %s\n' "$required_template" >&2; failed=1; }
  done

  while IFS= read -r feature_dir; do
    state_file="$feature_dir/state.yml"
    if [[ ! -f "$state_file" ]]; then
      printf 'WARN missing feature state, run agentflow state migrate or recreate state: %s\n' "$state_file" >&2
      missing_feature_state=1
      failed=1
      continue
    fi
    for required_template in id title type stage status; do
      if [[ -z "$(feature_state_value "$feature_dir" "$required_template")" ]]; then
        printf 'FAIL feature state missing %s: %s\n' "$required_template" "$state_file" >&2
        failed=1
      fi
    done
    if ! valid_feature_type "$(feature_type_for_dir "$feature_dir")"; then
      printf 'FAIL invalid feature type in %s\n' "$state_file" >&2
      failed=1
    fi
  done < <(find "$FEATURE_DIR" -maxdepth 1 -type d -name 'FEATURE-[0-9][0-9][0-9]-*' 2>/dev/null | sort)

  if [[ "$missing_feature_state" -eq 1 && -f "$(state_features_file)" ]]; then
    printf 'WARN legacy global state exists and feature state files are missing. Run: agentflow state migrate\n' >&2
  fi

  check_task_board_generated_header || failed=1
  check_task_board_fresh || failed=1

  if [[ -x "$PROJECT_ROOT/.git/hooks/pre-commit" && -x "$PROJECT_ROOT/.git/hooks/pre-push" ]]; then
    printf 'OK git hooks installed\n'
  else
    printf 'WARN git hooks are not installed. Run: agentflow install-hooks\n' >&2
  fi

  if git_root="$(git -C "$PROJECT_ROOT" rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ "$git_root" == "$PROJECT_ROOT" ]]; then
      printf 'OK trusted project root: %s\n' "$PROJECT_ROOT"
    else
      printf 'WARN current directory is inside git root, not the git root: %s\n' "$git_root" >&2
    fi
  else
    printf 'WARN project is not a git repository\n' >&2
  fi

  return "$failed"
}

install_hooks() {
  local hooks_dir agentflow_cmd
  hooks_dir="$PROJECT_ROOT/.git/hooks"
  if [[ ! -d "$hooks_dir" ]]; then
    printf 'Cannot install hooks outside a git repository: %s\n' "$PROJECT_ROOT" >&2
    exit 1
  fi
  agentflow_cmd="$PROJECT_ROOT/bin/agentflow"
  [[ -x "$agentflow_cmd" ]] || agentflow_cmd="agentflow"
  cat > "$hooks_dir/pre-commit" <<HOOK
#!/usr/bin/env sh
echo "agentflow pre-commit: running warning checks"
"$agentflow_cmd" doctor || echo "agentflow pre-commit warning: doctor reported issues"
"$agentflow_cmd" board render --check || echo "agentflow pre-commit warning: task board is stale"
exit 0
HOOK
  cat > "$hooks_dir/pre-push" <<HOOK
#!/usr/bin/env sh
echo "agentflow pre-push: running warning checks"
"$agentflow_cmd" doctor || echo "agentflow pre-push warning: doctor reported issues"
"$agentflow_cmd" check --all || echo "agentflow pre-push warning: check --all reported issues"
exit 0
HOOK
  chmod +x "$hooks_dir/pre-commit" "$hooks_dir/pre-push"
  printf 'Installed warning hooks:\n'
  printf '  %s\n' "$hooks_dir/pre-commit"
  printf '  %s\n' "$hooks_dir/pre-push"
}

init_ci_github() {
  local workflow_dir workflow_file
  workflow_dir="$PROJECT_ROOT/.github/workflows"
  workflow_file="$workflow_dir/agentflow.yml"
  mkdir -p "$workflow_dir"
  cat > "$workflow_file" <<'YAML'
name: AgentFlow

on:
  pull_request:
  push:

jobs:
  guard:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: AgentFlow doctor
        run: bin/agentflow doctor
      - name: AgentFlow check
        run: bin/agentflow check --all
      - name: AgentFlow board freshness
        run: bin/agentflow board render --check
YAML
  printf 'Wrote GitHub Actions workflow: %s\n' "$workflow_file"
}

rules_body() {
  cat <<'TEXT'
# AgentFlow Rules

Before editing code:
1. Read AGENTS.md
2. Identify current feature
3. Run agentflow feature status
4. If no feature exists, ask whether to create one
5. Do not edit generated files directly
6. Do not bypass gate for major/sensitive features

Generated files are render outputs. Do not edit project-docs/03_TASK_BOARD.md directly.
Source of truth for feature progress is features/FEATURE-XXX/state.yml.
TEXT
}

init_rules_one() {
  local target="$1"
  case "$target" in
    cursor)
      mkdir -p "$PROJECT_ROOT/.cursor"
      rules_body > "$PROJECT_ROOT/.cursor/rules.md"
      printf 'Wrote Cursor rules: %s\n' "$PROJECT_ROOT/.cursor/rules.md"
      ;;
    cline)
      rules_body > "$PROJECT_ROOT/.clinerules"
      printf 'Wrote Cline rules: %s\n' "$PROJECT_ROOT/.clinerules"
      ;;
    codex)
      rules_body > "$PROJECT_ROOT/AGENTS.agentflow-rules.md"
      printf 'Wrote Codex supplemental rules: %s\n' "$PROJECT_ROOT/AGENTS.agentflow-rules.md"
      ;;
    *)
      printf 'Unsupported rules target: %s\n' "$target" >&2
      exit 1
      ;;
  esac
}

init_rules() {
  local target="$1"
  case "$target" in
    all)
      init_rules_one cursor
      init_rules_one cline
      init_rules_one codex
      ;;
    cursor|cline|codex)
      init_rules_one "$target"
      ;;
    *)
      printf 'Usage: agentflow init-rules cursor|cline|codex|all\n' >&2
      exit 1
      ;;
  esac
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  case "$1" in
    --version|-v|version)
      package_version
      ;;
    init)
      shift
      PROFILE="$(parse_profile "$@")"
      init_project "$PROFILE"
      ;;
    feature)
      shift
      handle_feature_command "$@"
      ;;
    architecture)
      shift
      handle_architecture_command "$@"
      ;;
    board)
      shift
      handle_board_command "$@"
      ;;
    module)
      shift
      handle_module_command "$@"
      ;;
    reuse)
      shift
      handle_reuse_command "$@"
      ;;
    stage)
      shift
      handle_stage_command "$@"
      ;;
    state)
      if [[ "${2:-}" == "migrate" ]]; then
        migrate_feature_state
      else
        usage
        exit 1
      fi
      ;;
    update)
      case "${2:-}" in
        --check|check|"")
          update_project "check"
          ;;
        --apply|apply)
          update_project "apply"
          ;;
        *)
          usage
          exit 1
          ;;
      esac
      ;;
    doctor)
      doctor_check
      ;;
    install-hooks)
      install_hooks
      ;;
    init-ci)
      if [[ "${2:-}" == "github" ]]; then
        init_ci_github
      else
        usage
        exit 1
      fi
      ;;
    init-rules)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      init_rules "$2"
      ;;
    approve)
      if [[ $# -lt 4 ]]; then usage; exit 1; fi
      approve_feature_stage "$2" "$(parse_stage_flag "--stage" "${@:3}")"
      ;;
    check)
      if [[ "${2:-}" == "--all" ]]; then
        check_all_features
      elif [[ $# -ge 2 ]]; then
        check_task_board_generated_header
        check_feature "$2"
      else
        usage
        exit 1
      fi
      ;;
    verify)
      if [[ $# -lt 4 ]]; then usage; exit 1; fi
      verify_feature "$2" "$(parse_stage_flag "--stage" "${@:3}")"
      ;;
    gate)
      if [[ $# -ge 3 && "$3" == --to* ]]; then
        gate_to_stage "$2" "$(parse_stage_flag "--to" "${@:3}")"
      elif [[ $# -eq 3 ]]; then
        gate_stage_status "$2" "$3"
      else
        usage
        exit 1
      fi
      ;;
    context)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      build_active_context "$(feature_path "$2")"
      ;;
    status)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      print_status "$2"
      ;;
    sync-tasks)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      sync_tasks_for_feature "$2"
      ;;
    dispatch)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      shift
      handle_dispatch_command "$@"
      ;;
    archive)
      if [[ $# -lt 2 ]]; then usage; exit 1; fi
      archive_feature "$2"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
